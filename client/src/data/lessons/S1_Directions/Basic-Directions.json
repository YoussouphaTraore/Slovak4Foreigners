    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "At the hospital, the receptionist says the doctor's office is vpravo. Which way do you go?",
          "instruction": "Choose the correct direction",
          "choices": [
            "Left",
            "Right",
            "Up",
            "Down"
          ],
          "answer": "Right",
          "answerMeaning": "Vpravo = right."
        },
        {
          "situation": "Someone says the office is vľavo. Which way do you go?",
          "instruction": "Choose the correct direction",
          "choices": [
            "Left",
            "Right",
            "Straight",
            "Down"
          ],
          "answer": "Left",
          "answerMeaning": "Vľavo = left."
        },
        {
          "situation": "The lift is broken and the office is on the third floor. Which direction do you need?",
          "instruction": "Choose the correct direction",
          "choices": [
            "Hore",
            "Dole",
            "Vľavo",
            "Vpravo"
          ],
          "answer": "Hore",
          "answerMeaning": "Hore = up / upstairs."
        },
        {
          "situation": "You are on the second floor and the pharmacy is on the ground floor. Which direction do you need?",
          "instruction": "Choose the correct direction",
          "choices": [
            "Hore",
            "Dole",
            "Vľavo",
            "Priamo"
          ],
          "answer": "Dole",
          "answerMeaning": "Dole = down / downstairs."
        },
        {
          "situation": "You need to ask where the bathroom is. Which phrase starts the question?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Kde je...?",
            "Moja adresa je...",
            "Koľko to stojí?",
            "Dobrú noc."
          ],
          "answer": "Kde je...?",
          "answerMeaning": "Kde je...? = Where is...?"
        }
      ]
    },
