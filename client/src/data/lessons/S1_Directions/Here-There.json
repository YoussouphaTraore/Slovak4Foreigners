    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "The ambulance dispatcher asks where you are. You are at that exact spot. What do you say?",
          "instruction": "Choose the best answer",
          "choices": [
            "Som tu.",
            "Som tam.",
            "Som ďaleko.",
            "Som vľavo."
          ],
          "answer": "Som tu.",
          "answerMeaning": "Tu = here. Som tu = I am here."
        },
        {
          "situation": "You can see the bank across the street. What do you say while pointing?",
          "instruction": "Choose the best answer",
          "choices": [
            "Je to tam.",
            "Je to tu.",
            "Je to hore.",
            "Je to dole."
          ],
          "answer": "Je to tam.",
          "answerMeaning": "Tam = there / over there."
        },
        {
          "situation": "A passer-by says: Je to blízko, päť minút pešo. Do you need a taxi?",
          "instruction": "Choose the best answer",
          "choices": [
            "No, it's near.",
            "Yes, it's far.",
            "No, it's left.",
            "Yes, it's upstairs."
          ],
          "answer": "No, it's near.",
          "answerMeaning": "Blízko = near / close."
        },
        {
          "situation": "Someone says: Je to ďaleko. What does that mean?",
          "instruction": "Choose the meaning",
          "choices": [
            "It's far.",
            "It's here.",
            "It's left.",
            "It's upstairs."
          ],
          "answer": "It's far.",
          "answerMeaning": "Ďaleko = far / away."
        },
        {
          "situation": "You arrive at the correct door and want to say 'It's here.' Which phrase fits?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Je to tu.",
            "Je to tam.",
            "Je to ďaleko.",
            "Je to vpravo."
          ],
          "answer": "Je to tu.",
          "answerMeaning": "Je to tu. = It's here."
        }
      ]
    },
