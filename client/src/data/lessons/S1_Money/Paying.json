    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "The cashier asks 'Hotovosť alebo karta?' You want to pay by card.",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Platím v hotovosti.",
            "Platím kartou.",
            "Chcem drobné.",
            "Koľko to stojí?"
          ],
          "answer": "Platím kartou.",
          "answerMeaning": "Platím kartou = I'm paying by card. You will hear Hotovosť alebo karta? at many checkouts."
        },
        {
          "situation": "You left your bank card at home and have cash. What do you say?",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Platím kartou.",
            "Platím v hotovosti.",
            "Mám účtenku.",
            "Zadarmo."
          ],
          "answer": "Platím v hotovosti.",
          "answerMeaning": "Platím v hotovosti = I'm paying in cash. Hotovosť = cash."
        },
        {
          "situation": "You are ready to pay at the counter. What phrase starts the payment?",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Chcem zaplatiť.",
            "Mám drobné?",
            "Koľko je karta?",
            "Vstup zadarmo."
          ],
          "answer": "Chcem zaplatiť.",
          "answerMeaning": "Chcem zaplatiť = I want to pay."
        },
        {
          "situation": "You have only a 20 eur note. The item costs exactly 20 eur. What is ideal about this situation?",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Platím kartou.",
            "Máte drobné?",
            "Platím v hotovosti. Presná suma.",
            "Môžem dostať účtenku?"
          ],
          "answer": "Platím v hotovosti. Presná suma.",
          "answerMeaning": "Presná suma = exact amount. You don't need change."
        },
        {
          "situation": "A terminal says karta. What does it need?",
          "instruction": "Choose the correct meaning",
          "choices": [
            "A bank card",
            "A receipt",
            "Small change",
            "Free entry"
          ],
          "answer": "A bank card",
          "answerMeaning": "Karta = card / bank card."
        }
      ]
    },
