    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "At a restaurant you ask for the bill. What do you say?",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Môžem dostať účet?",
            "Máte drobné?",
            "Chcem peniaze.",
            "Koľko to stojí?"
          ],
          "answer": "Môžem dostať účet?",
          "answerMeaning": "Môžem dostať účet? = Can I get the bill? Účet is the restaurant bill."
        },
        {
          "situation": "You're expensing a business lunch and need proof of purchase. What do you ask before leaving?",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Koľko to stojí?",
            "Môžem dostať účtenku?",
            "Platím v hotovosti.",
            "Chcem drobné."
          ],
          "answer": "Môžem dostať účtenku?",
          "answerMeaning": "Môžem dostať účtenku? = Can I get a receipt? Účtenka is proof of purchase."
        },
        {
          "situation": "You hand a 5 eur note for a 2.50 eur coffee. The barista owes you coins. What word means small change?",
          "instruction": "Choose the correct word",
          "choices": [
            "Účtenka",
            "Karta",
            "Drobné",
            "Cena"
          ],
          "answer": "Drobné",
          "answerMeaning": "Drobné = small change / coins."
        },
        {
          "situation": "You only have a 20 eur note and need coins for a machine. What do you ask?",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Máte drobné?",
            "Je to zadarmo?",
            "Platím kartou.",
            "Mám účet."
          ],
          "answer": "Máte drobné?",
          "answerMeaning": "Máte drobné? = Do you have change?"
        },
        {
          "situation": "A waiter brings účet. What did they bring?",
          "instruction": "Choose the correct meaning",
          "choices": [
            "The bill",
            "The bank card",
            "Free entry",
            "Small coins"
          ],
          "answer": "The bill",
          "answerMeaning": "Účet = bill. Účtenka = receipt."
        }
      ]
    },
