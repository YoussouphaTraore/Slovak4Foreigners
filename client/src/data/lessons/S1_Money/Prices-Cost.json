    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You pick up an item at a market stall. What is the first thing you ask the seller?",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Koľko to stojí?",
            "Platím kartou.",
            "Chcem zaplatiť.",
            "Zadarmo?"
          ],
          "answer": "Koľko to stojí?",
          "answerMeaning": "Koľko to stojí? = How much does it cost? This is the natural opening when buying anything."
        },
        {
          "situation": "The price tag reads 15 eur. How much is the item?",
          "instruction": "Choose the correct amount",
          "choices": [
            "5 eur",
            "14 eur",
            "15 eur",
            "50 eur"
          ],
          "answer": "15 eur",
          "answerMeaning": "Pätnásť = fifteen, from the Numbers topic. Eur is the short everyday form of euro."
        },
        {
          "situation": "You see a sign in a museum that says 'Vstup zadarmo.' What does it mean?",
          "instruction": "Choose the correct meaning",
          "choices": [
            "Entry costs money",
            "Entry is free",
            "Entry needs a card",
            "Entry needs cash"
          ],
          "answer": "Entry is free",
          "answerMeaning": "Vstup zadarmo = Entry is free. Zadarmo = free of charge."
        },
        {
          "situation": "A plastic bag costs 5 centov. What is centov connected to?",
          "instruction": "Choose the correct meaning",
          "choices": [
            "Cents",
            "Cards",
            "Receipts",
            "Bills"
          ],
          "answer": "Cents",
          "answerMeaning": "Cent / centov = cent / cents. You will hear this for small prices."
        },
        {
          "situation": "The shelf label says cena. What does the label show?",
          "instruction": "Choose the correct meaning",
          "choices": [
            "The price",
            "The receipt",
            "The card",
            "The change"
          ],
          "answer": "The price",
          "answerMeaning": "Cena = price / cost. Shelf labels and menus use this word."
        }
      ]
    },
