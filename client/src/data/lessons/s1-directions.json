    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "A tourist asks where the Policajná stanica is. It's straight ahead. What do you tell them?",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Choďte vľavo.", "Choďte vpravo.", "Choďte priamo.", "Je to ďaleko."],
          "answer": "Choďte priamo.",
          "answerMeaning": "Go straight ahead. — Policajná stanica = Police station (from the Emergency lesson). Priamo = straight."
        },
        {
          "situation": "At the hospital (Nemocnica), the receptionist says the doctor's office is 'vpravo, druhé dvere.' Which way do you go?",
          "instruction": "Choose the correct direction",
          "choices": ["Up", "Left", "Right", "Down"],
          "answer": "Right",
          "answerMeaning": "Vpravo = Right — useful when navigating the Nemocnica from the Emergency lesson! (druhé dvere = second door)"
        },
        {
          "situation": "You need a pharmacy. A passer-by says 'Je to blízko, päť minút pešo.' Do you need a taxi?",
          "instruction": "Choose the most appropriate response",
          "choices": ["Áno, je to ďaleko.", "Nie, je to blízko.", "Neviem.", "Pomoc!"],
          "answer": "Nie, je to blízko.",
          "answerMeaning": "No, it's nearby. — päť minút pešo = five minutes on foot. Blízko = near, ďaleko = far. Neviem and Pomoc! are from the First Words lesson."
        },
        {
          "situation": "The lift is broken. The doctor's office is on the third floor. Which direction must you go?",
          "instruction": "Choose the correct direction",
          "choices": ["Dole", "Vonku", "Vpravo", "Hore"],
          "answer": "Hore",
          "answerMeaning": "Hore = Up / Upstairs — when the lift (výťah) is out of order, you will hear this a lot!"
        },
        {
          "situation": "You are on the second floor of the hospital. The pharmacy is on the ground floor. The nurse points and says you need to go...",
          "instruction": "Choose the correct direction",
          "choices": ["Hore", "Vonku", "Vpravo", "Dole"],
          "answer": "Dole",
          "answerMeaning": "Dole = Down / Downstairs — prízemie (ground floor) is always dole from any upper floor."
        },
        {
          "situation": "Someone is asking where the bank is. You can see the bank building from where you stand but it's across the street. What do you say?",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Je to tu.", "Je to tam.", "Je to blízko.", "Je to ďaleko."],
          "answer": "Je to tam.",
          "answerMeaning": "Tam = there / over there. Je to tam = it's over there. Use tam when pointing to something away from you."
        },
        {
          "situation": "The ambulance dispatcher asks exactly where you are. You are at that very spot. What do you say to confirm? (the Emergency lesson)",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Som tam.", "Som tu.", "Som blízko.", "Som ďaleko."],
          "answer": "Som tu.",
          "answerMeaning": "Tu = here. Som tu = I am here — use tu for your own position. Tam = over there (for pointing to something away from you)."
        },
        {
          "situation": "Someone gives you directions: 'Choďte priamo, potom vpravo pri nemocnici.' At what landmark do you turn right? (the Emergency lesson)",
          "instruction": "Choose the most appropriate answer",
          "choices": ["At the pharmacy", "At the police station", "At the hospital", "At the bank"],
          "answer": "At the hospital",
          "answerMeaning": "Nemocnica = hospital (the Emergency lesson). Combining directions with landmarks you already know — this is real navigation in Slovak."
        }
      ]
    },
