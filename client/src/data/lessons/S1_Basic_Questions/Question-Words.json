    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You point at a person and ask who it is. Which word do you need?",
          "instruction": "Choose the question word",
          "choices": [
            "Kto?",
            "Čo?",
            "Kde?",
            "Ako?"
          ],
          "answer": "Kto?",
          "answerMeaning": "Kto? = Who? Use it when asking about a person."
        },
        {
          "situation": "You point at a thing and ask what it is. Which word do you need?",
          "instruction": "Choose the question word",
          "choices": [
            "Čo?",
            "Kto?",
            "Kedy?",
            "Prečo?"
          ],
          "answer": "Čo?",
          "answerMeaning": "Čo? = What? Use it when asking about a thing or action."
        },
        {
          "situation": "You need to ask where the toilet is. Which word starts the question?",
          "instruction": "Choose the question word",
          "choices": [
            "Kde?",
            "Kedy?",
            "Ako?",
            "Prečo?"
          ],
          "answer": "Kde?",
          "answerMeaning": "Kde? = Where? Example: Kde je toaleta? = Where is the toilet?"
        },
        {
          "situation": "You want to ask when someone is coming. Which word do you need?",
          "instruction": "Choose the question word",
          "choices": [
            "Kedy?",
            "Kde?",
            "Kto?",
            "Čo?"
          ],
          "answer": "Kedy?",
          "answerMeaning": "Kedy? = When? Example: Kedy prídeš? = When will you come?"
        },
        {
          "situation": "You want to ask why something happened. Which word do you need?",
          "instruction": "Choose the question word",
          "choices": [
            "Prečo?",
            "Ako?",
            "Kde?",
            "Kto?"
          ],
          "answer": "Prečo?",
          "answerMeaning": "Prečo? = Why? Use it when asking for a reason."
        },
        {
          "situation": "You want to ask how to say a word in Slovak. Which word starts the question?",
          "instruction": "Choose the question word",
          "choices": [
            "Ako?",
            "Čo?",
            "Kedy?",
            "Kde?"
          ],
          "answer": "Ako?",
          "answerMeaning": "Ako? = How? Example: Ako sa povie...? = How do you say...?"
        }
      ]
    },
