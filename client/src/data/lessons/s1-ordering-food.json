    {
      "id": "ex6",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You walk into a restaurant alone. The waiter asks how many people. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["Stôl pre dvoch.", "Stôl pre jedného.", "Dám si kávu.", "Účet, prosím."],
          "answer": "Stôl pre jedného.",
          "answerMeaning": "Stôl pre jedného = A table for one. Jedného = one (the accusative form of jeden, from the Numbers lesson)."
        },
        {
          "situation": "The waiter brings the menu. You want soup. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["Čo odporúčate?", "Dám si polievku.", "Stôl pre dvoch.", "Účet, prosím."],
          "answer": "Dám si polievku.",
          "answerMeaning": "Dám si polievku = I'll have the soup. Dám si is the ordering pattern from the Verbs lesson — now applied with real food."
        },
        {
          "situation": "You can't decide what to order. What do you ask the waiter?",
          "instruction": "Choose the correct phrase",
          "choices": ["Niečo na pitie?", "Čo odporúčate?", "Bolo to chutné?", "Som pred budovou."],
          "answer": "Čo odporúčate?",
          "answerMeaning": "Čo odporúčate? = What do you recommend? A great phrase when the menu feels overwhelming."
        },
        {
          "situation": "You finished eating and want to pay. What do you say to the waiter?",
          "instruction": "Choose the correct phrase",
          "choices": ["Niečo na pitie?", "Dám si polievku.", "Môžem dostať účet?", "Čo odporúčate?"],
          "answer": "Môžem dostať účet?",
          "answerMeaning": "Môžem dostať účet? = Can I get the bill? Účet, from the Money lesson — reinforced here in its natural context."
        },
        {
          "situation": "The waiter asks if the meal was good. It was excellent. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["Je to pikantné.", "Áno, veľmi chutné.", "Som alergický.", "Niečo na pitie?"],
          "answer": "Áno, veľmi chutné.",
          "answerMeaning": "Áno, veľmi chutné = Yes, very tasty. Chutné from the Food lesson — your go-to compliment for good food."
        },
        {
          "situation": "You order food through a delivery app. The courier calls and asks where you are. You're in front of your building. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["Idem dole.", "Som pred budovou.", "Kde ste?", "Stôl pre jedného."],
          "answer": "Som pred budovou.",
          "answerMeaning": "Som pred budovou = I'm in front of the building. Pred = in front of, from the Positions lesson — used here to meet your delivery."
        },
        {
          "situation": "The courier has arrived but you're still inside. What do you say before heading down?",
          "instruction": "Choose the correct phrase",
          "choices": ["Idem dole.", "Som vonku.", "Stôl pre dvoch.", "Niečo na pitie?"],
          "answer": "Idem dole.",
          "answerMeaning": "Idem dole = I'm coming down. Dole = down, from the Directions lesson — Idem from the Verbs lesson."
        },
        {
          "situation": "You give your delivery address when ordering. What do you start with?",
          "instruction": "Choose the correct phrase",
          "choices": ["Moja adresa je...", "Dám si...", "Stôl pre jedného.", "Účet, prosím."],
          "answer": "Moja adresa je...",
          "answerMeaning": "Moja adresa je... = My address is... — from the My Address lesson, essential for any delivery order."
        }
      ]
    },
