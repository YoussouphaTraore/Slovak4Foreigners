    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You are at the doctor. You have a headache. Where do you point and what do you say?",
          "instruction": "Choose the correct word",
          "choices": [
            "Brucho",
            "Hlava",
            "Koleno",
            "Chrbát"
          ],
          "answer": "Hlava",
          "answerMeaning": "Hlava = Head. Bolí ma hlava = My head hurts. This is one of the most common complaints at a doctor."
        },
        {
          "situation": "The dentist asks you to open your mouth so they can check your teeth. Which two body words are they looking at?",
          "instruction": "Choose the correct pair",
          "choices": [
            "Nos a Ucho",
            "Ústa a Zuby",
            "Tvár a Vlasy",
            "Oko a Nos"
          ],
          "answer": "Ústa a Zuby",
          "answerMeaning": "Ústa = Mouth. Zuby = Teeth. Otvorte ústa = Open your mouth. You will hear this at a dental appointment."
        },
        {
          "situation": "The police need you to describe the person you saw. They had short dark hair. Which word do you use?",
          "instruction": "Choose the correct word",
          "choices": [
            "Tvár",
            "Hlava",
            "Vlasy",
            "Oko"
          ],
          "answer": "Vlasy",
          "answerMeaning": "Vlasy = Hair. Krátke tmavé vlasy = short dark hair. This connects directly to the Colors lesson."
        }
      ]
    },
    {
      "id": "ex6",
