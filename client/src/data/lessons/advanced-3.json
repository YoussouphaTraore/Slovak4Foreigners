        {
          "situation": "You want to say that today is Monday.",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Dnes je pondelok.", "Dnes je utorok.", "Zajtra je pondelok.", "Včera bol pondelok."],
          "answer": "Dnes je pondelok.",
          "answerMeaning": "Today is Monday."
        },
        {
          "situation": "Slovak counts time toward the next hour. 2:30 is 'half of the third hour'. How do you say it's 2:30?",
          "instruction": "Choose the correct phrase",
          "choices": ["Je pol druhej.", "Je pol tretej.", "Sú dve hodiny.", "Je dve a pol."],
          "answer": "Je pol tretej.",
          "answerMeaning": "It's half past two. (literally: half of the third hour)"
        },
        {
          "situation": "You want to ask a colleague what time it is.",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Koľko je hodín?", "O koľkej je?", "Aký je čas?", "Kedy je teraz?"],
          "answer": "Koľko je hodín?",
          "answerMeaning": "What time is it?"
        },
        {
          "situation": "The meeting is on Thursday. Slovak uses 'vo' (not 'v') before 'štvrtok'.",
          "instruction": "Choose the correct form",
          "choices": ["Stretnutie je v štvrtok.", "Stretnutie je vo štvrtok.", "Stretnutie je na štvrtok.", "Stretnutie je štvrtok."],
          "answer": "Stretnutie je vo štvrtok.",
          "answerMeaning": "The meeting is on Thursday. ('vo' is used before štvrtok)"
        },
        {
          "situation": "Your birthday is on May 15th. Slovak dates use the genitive form of ordinal numbers.",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Mám narodeniny pätnásteho mája.", "Mám narodeniny 15 máj.", "Mám narodeniny v pätnásty máj.", "Mám narodeniny pätnásť mája."],
