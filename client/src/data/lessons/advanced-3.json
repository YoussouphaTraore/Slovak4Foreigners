    {
      "id": "ex9",
      "type": "SMS_DIALOGUE",
      "scenario": "Arranging a coffee meeting with your Slovak colleague Zuzana during the work week.",
      "turns": [
        {
          "snailMessage": "Ahoj! Chcela by som sa s tebou stretnúť na káve. Kedy máš voľno tento týždeň?",
          "snailMessageEnglish": "Hi! I'd like to meet you for a coffee. When are you free this week?",
          "choices": [
            { "slovak": "Mám voľno v stredu alebo v piatok. Čo ti vyhovuje?", "english": "I'm free on Wednesday or Friday. What suits you?", "isCorrect": true },
            { "slovak": "Mám narodeniny v januári.", "english": "My birthday is in January.", "isCorrect": false },
            { "slovak": "Minulý rok som bol na dovolenke.", "english": "Last year I was on holiday.", "isCorrect": false }
          ],
          "snailReply": "Streda mi vyhovuje. O koľkej?",
          "snailReplyEnglish": "Wednesday works for me. What time?"
        },
        {
          "choices": [
            { "slovak": "Čo tak o pol jednej? Na obedňajšej prestávke.", "english": "How about half past twelve? During the lunch break.", "isCorrect": true },
            { "slovak": "Neviem koľko je hodín.", "english": "I don't know what time it is.", "isCorrect": false },
            { "slovak": "V sobotu ráno o siedmej.", "english": "On Saturday morning at seven.", "isCorrect": false }
          ],
          "snailReply": "Pol jednej je skvelé! Kde sa stretneme?",
          "snailReplyEnglish": "Half past twelve is great! Where shall we meet?"
        },
        {
          "choices": [
            { "slovak": "V kaviarni na Obchodnej ulici? Je to blízko kancelárie.", "english": "At the café on Obchodná Street? It's close to the office.", "isCorrect": true },
            { "slovak": "Neviem kde.", "english": "I don't know where.", "isCorrect": false },
            { "slovak": "Dnes je utorok, nie streda.", "english": "Today is Tuesday, not Wednesday.", "isCorrect": false }
          ],
          "snailReply": "Perfektné! Dám to do kalendára — streda, pol jednej, Obchodná. Správne?",
          "snailReplyEnglish": "Perfect! I'll put it in the calendar — Wednesday, half past twelve, Obchodná. Correct?"
        },
        {
          "choices": [
            { "slovak": "Áno, správne! Teším sa. Ak sa niečo zmení, napíšem ti.", "english": "Yes, correct! Looking forward to it. If anything changes, I'll text you.", "isCorrect": true },
            { "slovak": "Nie, je to v pondelok.", "english": "No, it's on Monday.", "isCorrect": false },
            { "slovak": "Budúci rok je lepší.", "english": "Next year is better.", "isCorrect": false }
          ],
          "snailReply": "Skvelé! Do videnia v stredu o pol jednej!",
          "snailReplyEnglish": "Great! See you on Wednesday at half past twelve!"
        },
        {
          "choices": [
            { "slovak": "Čau, Zuzana! Dobrý zvyšok dňa!", "english": "Bye, Zuzana! Have a good rest of the day!", "isCorrect": true },
            { "slovak": "Kedy je streda?", "english": "When is Wednesday?", "isCorrect": false },
            { "slovak": "Zajtra je piatok.", "english": "Tomorrow is Friday.", "isCorrect": false }
          ],
          "snailReply": "Aj tebe! Do stredy!",
          "snailReplyEnglish": "You too! See you Wednesday!"
        }
      ]
