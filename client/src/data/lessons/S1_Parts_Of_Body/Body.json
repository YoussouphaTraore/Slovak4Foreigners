    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You have chest pressure and pain. You are calling 155. Which word tells the dispatcher where it hurts?",
          "instruction": "Choose the correct word",
          "choices": [
            "Chrbát",
            "Brucho",
            "Hruď",
            "Bok"
          ],
          "answer": "Hruď",
          "answerMeaning": "Hruď = Chest. Bolí ma hruď = My chest hurts. Chest pain is a 155 emergency — say this word clearly and immediately."
        },
        {
          "situation": "A doctor asks whether the pain is in your chest or your heart. Which Slovak word means heart?",
          "instruction": "Choose the correct word",
          "choices": [
            "Hruď",
            "Brucho",
            "Srdce",
            "Chrbát"
          ],
          "answer": "Srdce",
          "answerMeaning": "Srdce = Heart. Hruď is the chest wall. Srdce is the organ. A Slovak doctor will ask 'Hruď alebo srdce?' — this distinction matters."
        },
        {
          "situation": "You have been sitting at the computer all day and your back is aching. What do you tell your doctor?",
          "instruction": "Choose the correct word",
          "choices": [
            "Stehno",
            "Bok",
            "Srdce",
            "Chrbát"
          ],
          "answer": "Chrbát",
          "answerMeaning": "Chrbát = Back. Bolí ma chrbát = My back hurts. One of the most common complaints at a Slovak GP."
        },
        {
          "situation": "You ate something bad and now have stomach pain. Which word do you need at the pharmacy?",
          "instruction": "Choose the correct word",
          "choices": [
            "Srdce",
            "Hruď",
            "Brucho",
            "Stehno"
          ],
          "answer": "Brucho",
          "answerMeaning": "Brucho = Stomach / belly. Bolí ma brucho = My stomach hurts. The pharmacist will ask 'Bolí vás brucho?' very often."
        }
      ]
    },
