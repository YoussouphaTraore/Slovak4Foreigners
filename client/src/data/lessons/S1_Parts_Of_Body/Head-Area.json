    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You have a sore throat and ear pain. You are at the doctor. Which two words do you need?",
          "instruction": "Choose the correct pair",
          "choices": [
            "Nos a Ústa",
            "Krk a Ucho",
            "Vlasy a Tvár",
            "Zuby a Oči"
          ],
          "answer": "Krk a Ucho",
          "answerMeaning": "Krk = Neck / throat. Ucho = Ear. Bolí ma krk a ucho = My throat and ear hurt. Very common at a GP in Slovakia."
        },
        {
          "situation": "You are at the dentist. They ask what is hurting. You have a toothache.",
          "instruction": "Choose the correct word",
          "choices": [
            "Nos",
            "Ucho",
            "Zuby",
            "Krk"
          ],
          "answer": "Zuby",
          "answerMeaning": "Zuby = Teeth. Bolí ma zub = One tooth hurts. Bolí ma zuby = My teeth hurt. This is the first word you need at a Slovak dentist."
        },
        {
          "situation": "The police need you to describe the person you saw. They had short dark hair and blue eyes.",
          "instruction": "Which two words will you use?",
          "choices": [
            "Nos a Ústa",
            "Tvár a Krk",
            "Vlasy a Oči",
            "Uši a Zuby"
          ],
          "answer": "Vlasy a Oči",
          "answerMeaning": "Vlasy = Hair. Oči = Eyes. Krátke tmavé vlasy = short dark hair. Modré oči = blue eyes. Connects to the Colors lesson."
        }
      ]
    },
