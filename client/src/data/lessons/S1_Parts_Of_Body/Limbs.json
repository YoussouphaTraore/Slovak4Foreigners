    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You slipped on ice and hurt your ankle. The doctor points to the sole of your foot. Which word are they using?",
          "instruction": "Choose the correct word",
          "choices": [
            "Noha",
            "Prst",
            "Chodidlo",
            "Rameno"
          ],
          "answer": "Chodidlo",
          "answerMeaning": "Chodidlo = the sole of the foot, anatomically exact. Noha covers the whole leg and foot. At a doctor, chodidlo is more precise."
        },
        {
          "situation": "You dropped a pot of boiling water on your toe. Which word tells the pharmacist where you were burned?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Prst na ruke",
            "Prst na nohe",
            "Chodidlo",
            "Noha"
          ],
          "answer": "Prst na nohe",
          "answerMeaning": "Prst na nohe = toe. Prst alone usually means finger. Add 'na nohe' to specify toe."
        },
        {
          "situation": "You injured your shoulder playing sport. Which word do you use when calling the doctor?",
          "instruction": "Choose the correct word",
          "choices": [
            "Ruka",
            "Prst",
            "Noha",
            "Rameno"
          ],
          "answer": "Rameno",
          "answerMeaning": "Rameno = Shoulder. Bolí ma rameno = My shoulder hurts. Use this at any Slovak clinic or pharmacy."
        },
        {
          "situation": "Slovak uses one word for both hand AND arm. Which is it?",
          "instruction": "Choose the correct word",
          "choices": [
            "Prst",
            "Rameno",
            "Ruka",
            "Chodidlo"
          ],
          "answer": "Ruka",
          "answerMeaning": "Ruka = Hand / Arm. Context tells you which one. Bolí ma ruka is the phrase for both arm pain and hand pain."
        }
      ]
    },
