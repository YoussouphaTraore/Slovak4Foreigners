    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "A Slovak form says Obec. You live in Košice. What do you write?",
          "instruction": "Choose the best answer",
          "choices": [
            "Košice",
            "Slovensko",
            "040 01",
            "Hlavná"
          ],
          "answer": "Košice",
          "answerMeaning": "Obec means municipality. Cities count too, so you write the city name."
        },
        {
          "situation": "A form asks for Kraj. What kind of information is it asking for?",
          "instruction": "Choose the meaning",
          "choices": [
            "Region / county",
            "Street",
            "Flat number",
            "Postal code"
          ],
          "answer": "Region / county",
          "answerMeaning": "Kraj = region / county."
        },
        {
          "situation": "Your address is on a square, not a street. Which word helps?",
          "instruction": "Choose the correct word",
          "choices": [
            "Námestie",
            "Poschodie",
            "Byt",
            "PSČ"
          ],
          "answer": "Námestie",
          "answerMeaning": "Námestie = square / plaza."
        },
        {
          "situation": "Someone is speaking too fast while giving an address. What can you ask?",
          "instruction": "Choose the useful phrase",
          "choices": [
            "Napíšte to, prosím.",
            "Koľko to stojí?",
            "Som hladný.",
            "Dobrú noc."
          ],
          "answer": "Napíšte to, prosím.",
          "answerMeaning": "Napíšte to, prosím. = Write it down, please."
        },
        {
          "situation": "You need to say your postal code clearly. Which phrase starts it?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Moje PSČ je...",
            "Moja ulica je...",
            "Bývam v byte.",
            "Aká je vaša adresa?"
          ],
          "answer": "Moje PSČ je...",
          "answerMeaning": "Moje PSČ je... = My postal code is..."
        }
      ]
    },
