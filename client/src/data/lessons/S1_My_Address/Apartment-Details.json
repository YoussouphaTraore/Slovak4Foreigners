      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "A delivery driver asks for your flat number. Which Slovak phrase do you need?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Číslo bytu",
            "Číslo domu",
            "Mesto",
            "Ulica"
          ],
          "answer": "Číslo bytu",
          "answerMeaning": "Číslo bytu = flat number."
        },
        {
          "situation": "Your apartment block has entrances A, B, and C. A form asks for Vchod. What does it mean?",
          "instruction": "Choose the meaning",
          "choices": [
            "Entrance / staircase",
            "Postal code",
            "City",
            "Street"
          ],
          "answer": "Entrance / staircase",
          "answerMeaning": "Vchod = entrance / staircase."
        },
        {
          "situation": "Someone asks which floor you live on. Which word means floor?",
          "instruction": "Choose the correct word",
          "choices": [
            "Poschodie",
            "Byt",
            "Vchod",
            "Mesto"
          ],
          "answer": "Poschodie",
          "answerMeaning": "Poschodie = floor."
        },
        {
          "situation": "You live on the ground floor. Which word do you use?",
          "instruction": "Choose the correct word",
          "choices": [
            "Prízemie",
            "Poschodie",
            "Byt",
            "Vchod"
          ],
          "answer": "Prízemie",
          "answerMeaning": "Prízemie = ground floor."
        },
        {
          "situation": "You live in a flat, not a house. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Bývam v byte.",
            "Bývam v meste.",
            "Bývam na ulici.",
            "Moje PSČ je."
          ],
          "answer": "Bývam v byte.",
          "answerMeaning": "Bývam v byte. = I live in a flat."
        }
      ]
    },
