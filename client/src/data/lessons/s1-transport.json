    {
      "id": "ex6",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "Your colleague asks how you're getting to work. You take the train. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["Idem autobusom.", "Idem vlakom.", "Idem pešo.", "Idem autom."],
          "answer": "Idem vlakom.",
          "answerMeaning": "Idem vlakom = I'm going by train. Notice the -om ending on vlak when saying 'by train'."
        },
        {
          "situation": "You live near a tram line and it's the fastest way to the centre. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["Idem autobusom.", "Idem električkou.", "Idem pešo.", "Idem na bicykli."],
          "answer": "Idem električkou.",
          "answerMeaning": "Idem električkou = I'm going by tram. Električka takes the -ou ending, slightly different from autobus/vlak/auto's -om ending — Slovak noun endings vary by gender."
        },
        {
          "situation": "It's a nice day and your flat is close to work. How do you say you're walking?",
          "instruction": "Choose the correct phrase",
          "choices": ["Idem pešo.", "Idem autom.", "Idem na bicykli.", "Idem vlakom."],
          "answer": "Idem pešo.",
          "answerMeaning": "Idem pešo = I'm going on foot. Pešo doesn't change form — it's already an adverb."
        },
        {
          "situation": "You want to ask how to get to the city centre. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Ako dlho to trvá?",
            "Ako sa dostanem do centra?",
            "Koľko to stojí?",
            "Kde je zastávka?"
          ],
          "answer": "Ako sa dostanem do centra?",
          "answerMeaning": "Ako sa dostanem do centra? = How do I get to the centre? The standard way to ask for travel directions."
        },
        {
          "situation": "You need to buy something before boarding the bus. What do you ask for?",
          "instruction": "Choose the correct word",
          "choices": ["Stanica", "Zastávka", "Cestovný lístok", "Autobus"],
          "answer": "Cestovný lístok",
          "answerMeaning": "Cestovný lístok = Ticket. Essential before boarding most public transport in Slovakia."
        },
        {
          "situation": "You are looking for where the train departs from. What are you looking for?",
          "instruction": "Choose the correct word",
          "choices": ["Zastávka", "Stanica", "Cestovný lístok", "Bicykel"],
          "answer": "Stanica",
          "answerMeaning": "Stanica = Station. Used for trains (vlaková stanica) and sometimes buses (autobusová stanica)."
        },
        {
          "situation": "You are looking for where the bus stops nearby, not the main station. What word do you use?",
          "instruction": "Choose the correct word",
          "choices": ["Stanica", "Zastávka", "Cestovný lístok", "Auto"],
          "answer": "Zastávka",
          "answerMeaning": "Zastávka = Stop. A smaller, local stopping point — different from a stanica (main station)."
        },
        {
          "situation": "You're deciding between car and bike for a short trip across town. You choose the bike. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["Idem autom.", "Idem na bicykli.", "Idem vlakom.", "Idem pešo."],
          "answer": "Idem na bicykli.",
          "answerMeaning": "Idem na bicykli = I'm going by bike. Unlike the other modes, bicykel uses na + the locative form rather than the -om ending."
        },
        {
          "situation": "You want to know the journey time before deciding how to travel. What do you ask?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Ako sa dostanem tam?",
            "Ako dlho to trvá?",
            "Koľko to stojí?",
            "Kde je stanica?"
          ],
          "answer": "Ako dlho to trvá?",
          "answerMeaning": "Ako dlho to trvá? = How long does it take? Already familiar from the Hospital lesson — now applied to travel."
        }
      ]
    },
