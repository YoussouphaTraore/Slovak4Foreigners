    {
      "id": "ex6",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "Your colleague asks what day it is today. It is Wednesday. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["Dnes je piatok.", "Dnes je streda.", "Dnes je pondelok.", "Dnes je nedeľa."],
          "answer": "Dnes je streda.",
          "answerMeaning": "Dnes je streda = Today is Wednesday. Dnes from this lesson + the day name."
        },
        {
          "situation": "Your doctor's appointment is on Friday. How do you say this?",
          "instruction": "Choose the correct phrase",
          "choices": ["V pondelok", "V piatok", "V utorok", "V nedeľu"],
          "answer": "V piatok",
          "answerMeaning": "V piatok = On Friday. The pattern V + day tells someone when something is happening."
        },
        {
          "situation": "You want to confirm a meeting for tomorrow. What word do you use?",
          "instruction": "Choose the correct word",
          "choices": ["Dnes", "Zajtra", "Včera", "Víkend"],
          "answer": "Zajtra",
          "answerMeaning": "Zajtra = Tomorrow. Essential when scheduling anything in Slovak."
        },
        {
          "situation": "You missed a delivery yesterday. How do you mention this to the courier?",
          "instruction": "Choose the correct word",
          "choices": ["Dnes", "Zajtra", "Včera", "Pondelok"],
          "answer": "Včera",
          "answerMeaning": "Včera = Yesterday. Doručenie bolo včera = The delivery was yesterday."
        },
        {
          "situation": "Most Slovak offices are closed on Saturday and Sunday. What do you call these two days together?",
          "instruction": "Choose the correct word",
          "choices": ["Pracovný deň", "Víkend", "Týždeň", "Streda"],
          "answer": "Víkend",
          "answerMeaning": "Víkend = Weekend. Sobota and Nedeľa together make up the víkend."
        },
        {
          "situation": "A shop sign says 'Otvorené: pondelok — piatok.' What does this mean?",
          "instruction": "Choose the correct meaning",
          "choices": [
            "Open only on Mondays",
            "Open Monday to Friday",
            "Open on weekends only",
            "Closed Monday and Friday"
          ],
          "answer": "Open Monday to Friday",
          "answerMeaning": "Pondelok — piatok = Monday to Friday. A very common way Slovak shops display their opening days."
        },
        {
          "situation": "Your friend says 'Uvidíme sa v sobotu.' What are they saying?",
          "instruction": "Choose the correct meaning",
          "choices": [
            "See you tomorrow",
            "See you on Saturday",
            "See you yesterday",
            "See you next week"
          ],
          "answer": "See you on Saturday",
          "answerMeaning": "Uvidíme sa v sobotu = See you on Saturday. Uvidíme sa v... + day is how Slovaks confirm plans."
        },
        {
          "situation": "You go to the gym Monday through Friday but never on weekends. How do you describe your routine?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Idem každý víkend.",
            "Idem každý pracovný deň.",
            "Idem každú nedeľu.",
            "Idem zajtra."
          ],
          "answer": "Idem každý pracovný deň.",
          "answerMeaning": "Idem každý pracovný deň = I go every working day. Pracovný deň = weekday, as opposed to víkend."
        }
      ]
    },
