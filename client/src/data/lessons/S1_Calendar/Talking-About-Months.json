    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "Your landlord says rent increases starting next month. What does that mean?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Tento mesiac",
            "Minulý mesiac",
            "Budúci mesiac",
            "Každý mesiac"
          ],
          "answer": "Budúci mesiac",
          "answerMeaning": "Budúci mesiac = next month."
        },
        {
          "situation": "Your gym membership was paid last month. How do you describe this?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Zaplatil som tento mesiac.",
            "Zaplatil som minulý mesiac.",
            "Zaplatím budúci mesiac.",
            "Platím každý týždeň."
          ],
          "answer": "Zaplatil som minulý mesiac.",
          "answerMeaning": "Minulý mesiac = last month."
        },
        {
          "situation": "You have lived here since March. Which phrase do you need?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Od marca",
            "V januári",
            "Budúci mesiac",
            "Minulý týždeň"
          ],
          "answer": "Od marca",
          "answerMeaning": "Od marca = since March."
        },
        {
          "situation": "A form asks whether you paid this month. Which phrase means this month?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Tento mesiac",
            "Minulý mesiac",
            "Budúci mesiac",
            "Od marca"
          ],
          "answer": "Tento mesiac",
          "answerMeaning": "Tento mesiac = this month."
        },
        {
          "situation": "You need to say something happened in March. Which phrase fits?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "V marci",
            "Od marca",
            "Budúci mesiac",
            "Minulý mesiac"
          ],
          "answer": "V marci",
          "answerMeaning": "V marci = in March."
        },
        {
          "situation": "Your rent will be higher next month. Which sentence uses bude?",
          "instruction": "Choose the future sentence",
          "choices": [
            "Nájom bude vyšší budúci mesiac.",
            "Nájom bol vyšší budúci mesiac.",
            "Nájom je minulý mesiac.",
            "Nájom bude včera."
          ],
          "answer": "Nájom bude vyšší budúci mesiac.",
          "answerMeaning": "Bude + budúci mesiac points to the future: The rent will be higher next month."
        }
      ]
    },
