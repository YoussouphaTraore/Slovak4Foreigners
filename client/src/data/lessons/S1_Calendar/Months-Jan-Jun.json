    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "Your residence permit expires in March. Which month is March?",
          "instruction": "Choose the correct month",
          "choices": [
            "Január",
            "Marec",
            "Jún",
            "December"
          ],
          "answer": "Marec",
          "answerMeaning": "Marec = March."
        },
        {
          "situation": "You arrived in Slovakia in January. Which word means January?",
          "instruction": "Choose the correct month",
          "choices": [
            "Január",
            "Február",
            "Máj",
            "Jún"
          ],
          "answer": "Január",
          "answerMeaning": "Január = January."
        },
        {
          "situation": "Your appointment is in June. Which word means June?",
          "instruction": "Choose the correct month",
          "choices": [
            "Marec",
            "Apríl",
            "Máj",
            "Jún"
          ],
          "answer": "Jún",
          "answerMeaning": "Jún = June."
        },
        {
          "situation": "A form says April. Which Slovak word matches?",
          "instruction": "Choose the correct month",
          "choices": [
            "Apríl",
            "Máj",
            "Jún",
            "Február"
          ],
          "answer": "Apríl",
          "answerMeaning": "Apríl = April."
        },
        {
          "situation": "Your birthday is in May. Which word means May?",
          "instruction": "Choose the correct month",
          "choices": [
            "Marec",
            "Máj",
            "Jún",
            "Január"
          ],
          "answer": "Máj",
          "answerMeaning": "Máj = May."
        },
        {
          "situation": "Your appointment will be in March. Which sentence uses bude?",
          "instruction": "Choose the future sentence",
          "choices": [
            "Termín bude v marci.",
            "Termín bol v marci.",
            "Termín je včera.",
            "Termín bol zajtra."
          ],
          "answer": "Termín bude v marci.",
          "answerMeaning": "Termín bude v marci. = The appointment will be in March."
        }
      ]
    },
