    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "Your birthday is in July. Which month is July?",
          "instruction": "Choose the correct month",
          "choices": [
            "Júl",
            "Marec",
            "September",
            "Január"
          ],
          "answer": "Júl",
          "answerMeaning": "Júl = July."
        },
        {
          "situation": "An official letter says your appointment is in October. Which month do you look for?",
          "instruction": "Choose the correct month",
          "choices": [
            "August",
            "September",
            "Október",
            "November"
          ],
          "answer": "Október",
          "answerMeaning": "Október = October."
        },
        {
          "situation": "You started work in September. Which word means September?",
          "instruction": "Choose the correct month",
          "choices": [
            "Júl",
            "August",
            "September",
            "December"
          ],
          "answer": "September",
          "answerMeaning": "September = September."
        },
        {
          "situation": "Your yearly renewal is in December. Which word means December?",
          "instruction": "Choose the correct month",
          "choices": [
            "Október",
            "November",
            "December",
            "August"
          ],
          "answer": "December",
          "answerMeaning": "December = December."
        },
        {
          "situation": "A form says November. Which Slovak word matches?",
          "instruction": "Choose the correct month",
          "choices": [
            "August",
            "September",
            "November",
            "Júl"
          ],
          "answer": "November",
          "answerMeaning": "November = November."
        },
        {
          "situation": "Your appointment will be in October. Which sentence uses bude?",
          "instruction": "Choose the future sentence",
          "choices": [
            "Termín bude v októbri.",
            "Termín bol v októbri.",
            "Termín je minulý týždeň.",
            "Termín bude včera."
          ],
          "answer": "Termín bude v októbri.",
          "answerMeaning": "Bude + v októbri makes this a future month sentence."
        }
      ]
    },
