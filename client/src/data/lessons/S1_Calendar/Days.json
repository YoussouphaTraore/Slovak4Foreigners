    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "Your appointment is on Friday. Which phrase means on Friday?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "V pondelok",
            "V piatok",
            "V utorok",
            "V nedeľu"
          ],
          "answer": "V piatok",
          "answerMeaning": "V piatok = on Friday."
        },
        {
          "situation": "Most offices are closed on Saturday and Sunday. What do you call these days together?",
          "instruction": "Choose the correct word",
          "choices": [
            "Pracovný deň",
            "Víkend",
            "Týždeň",
            "Streda"
          ],
          "answer": "Víkend",
          "answerMeaning": "Víkend = weekend."
        },
        {
          "situation": "A shop sign says 'Otvorené: pondelok - piatok.' What does it mean?",
          "instruction": "Choose the correct meaning",
          "choices": [
            "Open only Monday",
            "Open Monday to Friday",
            "Open weekends only",
            "Closed Friday"
          ],
          "answer": "Open Monday to Friday",
          "answerMeaning": "Pondelok - piatok = Monday to Friday."
        },
        {
          "situation": "Your friend says 'Uvidíme sa v sobotu.' What are they saying?",
          "instruction": "Choose the correct meaning",
          "choices": [
            "See you tomorrow",
            "See you on Saturday",
            "See you yesterday",
            "See you next week"
          ],
          "answer": "See you on Saturday",
          "answerMeaning": "Uvidíme sa v sobotu = See you on Saturday."
        },
        {
          "situation": "You go to the office every Monday. Which day is Monday?",
          "instruction": "Choose the correct word",
          "choices": [
            "Pondelok",
            "Utorok",
            "Streda",
            "Nedeľa"
          ],
          "answer": "Pondelok",
          "answerMeaning": "Pondelok = Monday."
        },
        {
          "situation": "Your appointment will be on Monday. Which sentence talks about the future?",
          "instruction": "Choose the sentence with future bude",
          "choices": [
            "Termín bude v pondelok.",
            "Termín bol v pondelok.",
            "Termín je včera.",
            "Termín bol zajtra."
          ],
          "answer": "Termín bude v pondelok.",
          "answerMeaning": "Bude marks the future: Termín bude v pondelok. = The appointment will be on Monday."
        }
      ]
    },
