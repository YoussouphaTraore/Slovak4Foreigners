    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "The team meeting was last week. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Schôdza bola budúci týždeň.",
            "Schôdza bola minulý týždeň.",
            "Schôdza bola tento mesiac.",
            "Schôdza je zajtra."
          ],
          "answer": "Schôdza bola minulý týždeň.",
          "answerMeaning": "Minulý týždeň = last week."
        },
        {
          "situation": "Your next dentist appointment is next week. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Je budúci týždeň.",
            "Je minulý týždeň.",
            "Je každý mesiac.",
            "Je dnes."
          ],
          "answer": "Je budúci týždeň.",
          "answerMeaning": "Budúci týždeň = next week."
        },
        {
          "situation": "You go to the gym every week. How do you describe this?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Idem tento týždeň.",
            "Idem každý týždeň.",
            "Idem budúci týždeň.",
            "Idem minulý týždeň."
          ],
          "answer": "Idem každý týždeň.",
          "answerMeaning": "Každý týždeň = every week."
        },
        {
          "situation": "You need to say something is happening this week. Which phrase fits?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Tento týždeň",
            "Minulý týždeň",
            "Budúci týždeň",
            "Každý mesiac"
          ],
          "answer": "Tento týždeň",
          "answerMeaning": "Tento týždeň = this week."
        },
        {
          "situation": "A form asks for a month, not a week. Which word means month?",
          "instruction": "Choose the correct word",
          "choices": [
            "Týždeň",
            "Mesiac",
            "Deň",
            "Víkend"
          ],
          "answer": "Mesiac",
          "answerMeaning": "Mesiac = month."
        },
        {
          "situation": "The repair will be next week. What sentence uses bude correctly?",
          "instruction": "Choose the future sentence",
          "choices": [
            "Oprava bude budúci týždeň.",
            "Oprava bola budúci týždeň.",
            "Oprava je minulý týždeň.",
            "Oprava bola zajtra."
          ],
          "answer": "Oprava bude budúci týždeň.",
          "answerMeaning": "Bude + budúci týždeň points to the future: The repair will be next week."
        }
      ]
    },
