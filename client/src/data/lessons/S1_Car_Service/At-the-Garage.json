    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You need the person who repairs cars. Which word means mechanic?",
          "instruction": "Choose the correct word",
          "choices": [
            "mechanik",
            "autoservis",
            "termín",
            "oprava"
          ],
          "answer": "mechanik",
          "answerMeaning": "mechanik = mechanic. This is the person who checks or repairs the car."
        },
        {
          "situation": "You are looking for a car service or garage. Which word fits?",
          "instruction": "Choose the correct word",
          "choices": [
            "autoservis",
            "mechanik",
            "čakať",
            "skontrolovať"
          ],
          "answer": "autoservis",
          "answerMeaning": "autoservis = car service / garage. Use it for the place where cars are checked and repaired."
        },
        {
          "situation": "You want to book a time at the garage. Which word means appointment?",
          "instruction": "Choose the correct word",
          "choices": [
            "termín",
            "oprava",
            "autoservis",
            "mechanik"
          ],
          "answer": "termín",
          "answerMeaning": "termín = appointment. Useful when booking a service visit."
        },
        {
          "situation": "The car needs a repair. Which word means repair?",
          "instruction": "Choose the correct word",
          "choices": [
            "oprava",
            "termín",
            "čakať",
            "mechanik"
          ],
          "answer": "oprava",
          "answerMeaning": "oprava = repair. You may hear it when the car needs work."
        },
        {
          "situation": "You ask the mechanic to check the car. Which word means to check?",
          "instruction": "Choose the correct word",
          "choices": [
            "skontrolovať",
            "čakať",
            "oprava",
            "autoservis"
          ],
          "answer": "skontrolovať",
          "answerMeaning": "skontrolovať = to check. Example: Prosím, skontrolovať auto. = Please check the car."
        },
        {
          "situation": "The mechanic says you must wait. Which word means to wait?",
          "instruction": "Choose the correct word",
          "choices": [
            "čakať",
            "skontrolovať",
            "termín",
            "mechanik"
          ],
          "answer": "čakať",
          "answerMeaning": "čakať = to wait. At a garage you may need to wait for the check or repair."
        }
      ]
    },
