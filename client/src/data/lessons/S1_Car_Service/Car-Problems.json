    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "Something is wrong with your car. Which word means problem?",
          "instruction": "Choose the correct word",
          "choices": [
            "problém",
            "olej",
            "batéria",
            "pokazené"
          ],
          "answer": "problém",
          "answerMeaning": "problém = problem. You can say Mám problém. = I have a problem."
        },
        {
          "situation": "Your car is broken. Which Slovak word fits with auto?",
          "instruction": "Choose the correct word",
          "choices": [
            "pokazené",
            "nefunguje",
            "olej",
            "batéria"
          ],
          "answer": "pokazené",
          "answerMeaning": "pokazené = broken. Auto je pokazené. = The car is broken."
        },
        {
          "situation": "The car does not work. Which phrase do you need?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "nefunguje",
            "svieti kontrolka",
            "problém",
            "olej"
          ],
          "answer": "nefunguje",
          "answerMeaning": "nefunguje = does not work. Auto nefunguje. = The car does not work."
        },
        {
          "situation": "A warning light is on in the car. Which phrase fits?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "svieti kontrolka",
            "nefunguje",
            "batéria",
            "pokazené"
          ],
          "answer": "svieti kontrolka",
          "answerMeaning": "svieti kontrolka = warning light is on. Kontrolka is an indicator or warning light."
        },
        {
          "situation": "The mechanic asks about the car battery. Which word means battery?",
          "instruction": "Choose the correct word",
          "choices": [
            "batéria",
            "olej",
            "problém",
            "kontrolka"
          ],
          "answer": "batéria",
          "answerMeaning": "batéria = battery. This can be a car battery or another battery."
        },
        {
          "situation": "The mechanic checks the oil. Which word means oil?",
          "instruction": "Choose the correct word",
          "choices": [
            "olej",
            "batéria",
            "nefunguje",
            "problém"
          ],
          "answer": "olej",
          "answerMeaning": "olej = oil. This is useful for car maintenance and engine problems."
        }
      ]
    },
