    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "The garage desk asks for your car documents. Which word means documents?",
          "instruction": "Choose the correct word",
          "choices": [
            "doklady",
            "poistenie",
            "náhradný diel",
            "kľúč od auta"
          ],
          "answer": "doklady",
          "answerMeaning": "doklady = documents. This is a general word for official papers or IDs."
        },
        {
          "situation": "Someone asks for your driver's license. Which phrase do you need?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "vodičský preukaz",
            "technický preukaz",
            "poistenie",
            "doklady"
          ],
          "answer": "vodičský preukaz",
          "answerMeaning": "vodičský preukaz = driver's license. Vodič means driver."
        },
        {
          "situation": "The mechanic asks for the vehicle registration document. Which phrase fits?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "technický preukaz",
            "vodičský preukaz",
            "náhradný diel",
            "kľúč od auta"
          ],
          "answer": "technický preukaz",
          "answerMeaning": "technický preukaz = vehicle registration document / technical certificate for the car."
        },
        {
          "situation": "You need to say insurance. Which word fits?",
          "instruction": "Choose the correct word",
          "choices": [
            "poistenie",
            "doklady",
            "technický preukaz",
            "náhradný diel"
          ],
          "answer": "poistenie",
          "answerMeaning": "poistenie = insurance. Useful for car damage, accidents, or documents."
        },
        {
          "situation": "The mechanic says the car needs a replacement part. Which phrase means replacement part?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "náhradný diel",
            "poistenie",
            "doklady",
            "vodičský preukaz"
          ],
          "answer": "náhradný diel",
          "answerMeaning": "náhradný diel = replacement part / spare part. You may hear this during repairs."
        },
        {
          "situation": "You need to give the car key to the mechanic. Which phrase means car key?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "kľúč od auta",
            "náhradný diel",
            "poistenie",
            "technický preukaz"
          ],
          "answer": "kľúč od auta",
          "answerMeaning": "kľúč od auta = car key. Od auta means of/from the car."
        }
      ]
    },
