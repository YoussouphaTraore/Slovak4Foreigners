    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You are at a garage and need to say car. Which Slovak word fits?",
          "instruction": "Choose the correct word",
          "choices": [
            "auto",
            "motor",
            "koleso",
            "brzdy"
          ],
          "answer": "auto",
          "answerMeaning": "auto = car. This is the basic everyday word."
        },
        {
          "situation": "You cannot open or start the car because you lost this. Which word means key?",
          "instruction": "Choose the correct word",
          "choices": [
            "kľúč",
            "auto",
            "pneumatika",
            "motor"
          ],
          "answer": "kľúč",
          "answerMeaning": "kľúč = key. Use it for a house key or car key."
        },
        {
          "situation": "The car does not start. You want to point to the engine. Which word do you need?",
          "instruction": "Choose the correct word",
          "choices": [
            "motor",
            "koleso",
            "brzdy",
            "auto"
          ],
          "answer": "motor",
          "answerMeaning": "motor = engine. It is one of the first words to know at a car service."
        },
        {
          "situation": "You point to one wheel of the car. Which word means wheel?",
          "instruction": "Choose the correct word",
          "choices": [
            "koleso",
            "pneumatika",
            "kľúč",
            "motor"
          ],
          "answer": "koleso",
          "answerMeaning": "koleso = wheel. Pneumatika is the tire on the wheel."
        },
        {
          "situation": "The rubber part on the wheel is flat. Which word means tire?",
          "instruction": "Choose the correct word",
          "choices": [
            "pneumatika",
            "koleso",
            "brzdy",
            "auto"
          ],
          "answer": "pneumatika",
          "answerMeaning": "pneumatika = tire. Use it for a flat tire or tire change."
        },
        {
          "situation": "The car has trouble stopping. Which word means brakes?",
          "instruction": "Choose the correct word",
          "choices": [
            "brzdy",
            "motor",
            "pneumatika",
            "kľúč"
          ],
          "answer": "brzdy",
          "answerMeaning": "brzdy = brakes. This is important safety vocabulary."
        }
      ]
    },
