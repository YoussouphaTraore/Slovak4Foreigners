    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "Your tire is flat on the road. Which Slovak word do you need?",
          "instruction": "Choose the correct word",
          "choices": [
            "defekt",
            "palivo",
            "benzín",
            "nafta"
          ],
          "answer": "defekt",
          "answerMeaning": "defekt = flat tire / puncture. It is the natural word when a tire is flat or damaged."
        },
        {
          "situation": "You need the spare wheel from the car. Which phrase means spare wheel?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "rezervné koleso",
            "čerpacia stanica",
            "defekt",
            "palivo"
          ],
          "answer": "rezervné koleso",
          "answerMeaning": "rezervné koleso = spare wheel. Rezervné means spare or reserve."
        },
        {
          "situation": "The car has no fuel. Which word means fuel?",
          "instruction": "Choose the correct word",
          "choices": [
            "palivo",
            "benzín",
            "nafta",
            "defekt"
          ],
          "answer": "palivo",
          "answerMeaning": "palivo = fuel. It is the general word before choosing petrol or diesel."
        },
        {
          "situation": "Your car uses petrol / gasoline. Which word do you ask for?",
          "instruction": "Choose the correct word",
          "choices": [
            "benzín",
            "nafta",
            "palivo",
            "rezervné koleso"
          ],
          "answer": "benzín",
          "answerMeaning": "benzín = petrol / gasoline. Use it at a gas station for petrol cars."
        },
        {
          "situation": "Your car uses diesel. Which Slovak word means diesel?",
          "instruction": "Choose the correct word",
          "choices": [
            "nafta",
            "benzín",
            "palivo",
            "defekt"
          ],
          "answer": "nafta",
          "answerMeaning": "nafta = diesel. Do not confuse it with benzín."
        },
        {
          "situation": "You need a place to refuel. Which phrase means gas station?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "čerpacia stanica",
            "rezervné koleso",
            "defekt",
            "nafta"
          ],
          "answer": "čerpacia stanica",
          "answerMeaning": "čerpacia stanica = gas station / petrol station. You can also hear benzínka informally."
        }
      ]
    },
