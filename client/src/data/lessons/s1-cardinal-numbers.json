    {
      "id": "ex7",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "The receptionist says your appointment is on the tretie poschodie. Which floor is that?",
          "instruction": "Choose the correct floor",
          "choices": ["1st floor", "2nd floor", "3rd floor", "5th floor"],
          "answer": "3rd floor",
          "answerMeaning": "Tretie poschodie = 3rd floor. Tretí/tretie = third — ordinal numbers are used for floors in Slovak buildings."
        },
        {
          "situation": "You are buying 3 apples at the market. How do you say the number?",
          "instruction": "Choose the correct word",
          "choices": ["dva", "tri", "štyri", "päť"],
          "answer": "tri",
          "answerMeaning": "Tri = Three. Tri jablká = three apples."
        },
        {
          "situation": "You are queueing and someone asks what position you are in line. You are first. What do you say?",
          "instruction": "Choose the correct word",
          "choices": ["jeden", "prvý", "druhý", "desať"],
          "answer": "prvý",
          "answerMeaning": "Prvý = First (ordinal). Jeden would be the cardinal 'one' — not used for position in a queue."
        },
        {
          "situation": "Your apartment is on the second floor. How do you tell a delivery driver?",
          "instruction": "Choose the correct phrase",
          "choices": ["Som na prvom poschodí.", "Som na druhom poschodí.", "Som na treťom poschodí.", "Som na desiatom poschodí."],
          "answer": "Som na druhom poschodí.",
          "answerMeaning": "Som na druhom poschodí = I am on the second floor. Druhý = second."
        },
        {
          "situation": "The shop assistant tells you the price is €100. How much is that?",
          "instruction": "Choose the correct amount",
          "choices": ["10 eur", "50 eur", "100 eur", "1000 eur"],
          "answer": "100 eur",
          "answerMeaning": "Sto = One hundred. A key number for prices."
        },
        {
          "situation": "You need to buy 20 stamps at the post office. How do you say the number?",
          "instruction": "Choose the correct word",
          "choices": ["desať", "dvadsať", "tridsať", "sto"],
          "answer": "dvadsať",
          "answerMeaning": "Dvadsať = Twenty. Dvadsať známok = twenty stamps."
        }
      ]
