    {
      "id": "ex4",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You are at the office and say: 'I have a document.' Which phrase is correct?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Mám dokument.",
            "Má dokument.",
            "Máte dokument.",
            "Majú dokument."
          ],
          "answer": "Mám dokument.",
          "answerMeaning": "Mám = I have."
        },
        {
          "situation": "Your flatmate asks if you want coffee. You do. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Chce kávu.",
            "Chcem kávu.",
            "Chcete kávu.",
            "Chceš kávu."
          ],
          "answer": "Chcem kávu.",
          "answerMeaning": "Chcem = I want."
        },
        {
          "situation": "At Foreign Police, you say: 'I need a document.' Which is correct?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Potrebuje dokument.",
            "Potrebujem dokument.",
            "Potrebujete dokument.",
            "Potrebujú dokument."
          ],
          "answer": "Potrebujem dokument.",
          "answerMeaning": "Potrebujem = I need."
        },
        {
          "situation": "A friend asks if you can speak Slovak a little. You can. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Viem trochu.",
            "Vieš trochu.",
            "Viete trochu.",
            "Vie trochu."
          ],
          "answer": "Viem trochu.",
          "answerMeaning": "Viem can mean I know or I can."
        },
        {
          "situation": "Someone asks what you do at work. You want to say: 'I do cleaning.' Which starts the answer?",
          "instruction": "Choose the correct word",
          "choices": [
            "Robím",
            "Robíš",
            "Robí",
            "Robíte"
          ],
          "answer": "Robím",
          "answerMeaning": "Robím = I do."
        },
        {
          "situation": "You arrive without your wallet. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Mám peňaženku.",
            "Chcem peňaženku.",
            "Zabudol som peňaženku.",
            "Potrebujem peňaženku."
          ],
          "answer": "Zabudol som peňaženku.",
          "answerMeaning": "Zabudol som = I forgot."
        }
      ]
    },
