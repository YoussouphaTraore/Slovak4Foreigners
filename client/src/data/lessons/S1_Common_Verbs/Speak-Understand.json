    {
      "id": "ex4",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "The officer asks if you speak Slovak. You say: 'I speak a little.'",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Hovorí trochu.",
            "Hovoríte trochu.",
            "Hovorím trochu.",
            "Hovoríš trochu."
          ],
          "answer": "Hovorím trochu.",
          "answerMeaning": "Hovorím = I speak."
        },
        {
          "situation": "You want to ask a doctor formally: 'Do you speak English?'",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Hovorím po anglicky?",
            "Hovorí po anglicky?",
            "Hovoríte po anglicky?",
            "Hovoria po anglicky?"
          ],
          "answer": "Hovoríte po anglicky?",
          "answerMeaning": "Hovoríte = you speak, formal or plural."
        },
        {
          "situation": "You understand the instructions. What can you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Rozumiem.",
            "Nerozumiem.",
            "Hovoríte?",
            "Viete?"
          ],
          "answer": "Rozumiem.",
          "answerMeaning": "Rozumiem = I understand."
        },
        {
          "situation": "You do not understand what the officer said. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Rozumiem.",
            "Nerozumiem.",
            "Viete?",
            "Vieš?"
          ],
          "answer": "Nerozumiem.",
          "answerMeaning": "Nerozumiem = I don't understand."
        },
        {
          "situation": "You ask a receptionist formally: 'Do you know where the office is?' Which opening is correct?",
          "instruction": "Choose the correct word",
          "choices": [
            "Vieš",
            "Viem",
            "Viete",
            "Vie"
          ],
          "answer": "Viete",
          "answerMeaning": "Viete = do you know, formal or plural."
        },
        {
          "situation": "You ask a friend informally: 'Do you know where the office is?' Which opening is correct?",
          "instruction": "Choose the correct word",
          "choices": [
            "Viete",
            "Viem",
            "Vieš",
            "Vie"
          ],
          "answer": "Vieš",
          "answerMeaning": "Vieš = do you know, informal."
        }
      ]
    },
