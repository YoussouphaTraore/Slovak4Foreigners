    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You are queueing and you are first. What word do you need?",
          "instruction": "Choose the correct word",
          "choices": [
            "jeden",
            "prvý",
            "druhý",
            "piaty"
          ],
          "answer": "prvý",
          "answerMeaning": "Prvý = first. Jeden means one, not first in line."
        },
        {
          "situation": "Your apartment is on the second floor. How do you tell a delivery driver?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Som na prvom poschodí.",
            "Som na druhom poschodí.",
            "Som na treťom poschodí.",
            "Som na piatom poschodí."
          ],
          "answer": "Som na druhom poschodí.",
          "answerMeaning": "Som na druhom poschodí = I am on the second floor."
        },
        {
          "situation": "The receptionist says tretie poschodie. Which floor is that?",
          "instruction": "Choose the correct floor",
          "choices": [
            "1st floor",
            "2nd floor",
            "3rd floor",
            "5th floor"
          ],
          "answer": "3rd floor",
          "answerMeaning": "Tretie poschodie = third floor."
        },
        {
          "situation": "It is your first visit to Slovakia. Which form fits návšteva?",
          "instruction": "Choose the correct word",
          "choices": [
            "prvá",
            "druhá",
            "tretia",
            "piata"
          ],
          "answer": "prvá",
          "answerMeaning": "Prvá návšteva = first visit."
        },
        {
          "situation": "This is your second question. Which word fits otázka?",
          "instruction": "Choose the correct word",
          "choices": [
            "prvá",
            "druhá",
            "tretia",
            "štvrtá"
          ],
          "answer": "druhá",
          "answerMeaning": "Druhá otázka = second question."
        }
      ]
    },
