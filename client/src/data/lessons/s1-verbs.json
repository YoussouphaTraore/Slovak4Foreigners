    {
      "id": "ex8",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You don't understand what the officer said. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["Rozumiete.", "Nerozumieš.", "Nerozumiem.", "Rozumiem."],
          "answer": "Nerozumiem.",
          "answerMeaning": "Nerozumiem = I don't understand. Ja form. Ne- makes any verb negative. Your most important phrase at any official appointment."
        },
        {
          "situation": "Your colleague says 'Chcem ísť domov.' What do they want?",
          "instruction": "Choose the correct meaning",
          "choices": [
            "They want to go to work",
            "They want to go home",
            "They want to come with you",
            "They want to stay"
          ],
          "answer": "They want to go home",
          "answerMeaning": "Chcem = I want. Ísť = to go. Domov = home. Two verbs from this lesson in one sentence."
        },
        {
          "situation": "You are at a restaurant. You say 'I'll have the soup.' Which is correct?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Dám si polievku.",
            "Dáš si polievku.",
            "Dá si polievku.",
            "Dajú si polievku."
          ],
          "answer": "Dám si polievku.",
          "answerMeaning": "Dám si = I'll have. Dám = I give (Ja form). This is the standard phrase for ordering food in Slovak restaurants."
        },
        {
          "situation": "The officer says 'Rozumiete?' after explaining something. What are they asking?",
          "instruction": "Choose the correct meaning",
          "choices": [
            "Do you agree?",
            "Do you understand?",
            "Do you have questions?",
            "Do you speak Slovak?"
          ],
          "answer": "Do you understand?",
          "answerMeaning": "Rozumiete = You understand (Vy form — formal). Used as a question it means 'Do you understand?' Officers use this to check you followed their instructions."
        },
        {
          "situation": "You are calling the doctor's office. You say 'I am coming at ten o'clock.' Which is correct?",
          "instruction": "Choose the correct phrase",
          "choices": ["Príde o desiatej.", "Prídem o desiatej.", "Prídeš o desiatej.", "Prídete o desiatej."],
          "answer": "Prídem o desiatej.",
          "answerMeaning": "Prídem = I am coming. Ja form. O desiatej = at ten o'clock."
        }
      ]
    },
