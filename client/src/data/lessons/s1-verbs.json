    {
      "id": "ex6",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You left your wallet at home. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Zabudnem peňaženku.",
            "Zabudol som peňaženku.",
            "Zabudne peňaženku.",
            "Zabudnete peňaženku."
          ],
          "answer": "Zabudol som peňaženku.",
          "answerMeaning": "Zabudol som = I forgot (male). Zabudla som = I forgot (female). Peňaženka = wallet."
        },
        {
          "situation": "You are at the Foreign Police. You say 'I need a document.' Which is correct?",
          "instruction": "Choose the correct form",
          "choices": [
            "Potrebuje dokument.",
            "Potrebujem dokument.",
            "Potrebujete dokument.",
            "Potrebujú dokument."
          ],
          "answer": "Potrebujem dokument.",
          "answerMeaning": "Potrebujem = I need. Ja form."
        },
        {
          "situation": "The officer asks if you speak Slovak. You say 'I speak a little.' Which is correct?",
          "instruction": "Choose the correct form",
          "choices": [
            "Hovorí trochu.",
            "Hovoríte trochu.",
            "Hovorím trochu.",
            "Hovoríš trochu."
          ],
          "answer": "Hovorím trochu.",
          "answerMeaning": "Hovorím = I speak. Ja form."
        },
        {
          "situation": "Your flatmate asks if you want coffee. You do. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Chce kávu.",
            "Chcem kávu.",
            "Chcete kávu.",
            "Chceš kávu."
          ],
          "answer": "Chcem kávu.",
          "answerMeaning": "Chcem = I want. Ja form."
        },
        {
          "situation": "You ask your colleague: 'Do you know where the office is?' Which form do you use?",
          "instruction": "Choose the correct form",
          "choices": ["Viem", "Vie", "Vieš", "Vedia"],
          "answer": "Vieš",
          "answerMeaning": "Vieš = You know (informal, one person). Ty form."
        },
        {
          "situation": "You are at the supermarket checkout. You want to pay by card. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["Platí kartou.", "Platíš kartou.", "Platím kartou.", "Platíte kartou."],
          "answer": "Platím kartou.",
          "answerMeaning": "Platím = I pay. Kartou = by card. Ja form — you are the one paying."
        },
        {
          "situation": "The cashier says 'Platíte kartou alebo hotovosťou?' What are they asking?",
          "instruction": "Choose the correct meaning",
          "choices": [
            "Do you want a receipt?",
            "Are you paying by card or cash?",
            "Do you have enough money?",
            "Do you want change?"
          ],
          "answer": "Are you paying by card or cash?",
          "answerMeaning": "Platíte = You pay (Vy form — formal). Kartou = by card. Hotovosťou = in cash. You will hear this at every checkout in Slovakia."
        },
        {
          "situation": "You want to ask your colleague formally: 'Do you speak English?' Which is correct?",
          "instruction": "Choose the correct phrase",
          "choices": ["Hovorím po anglicky?", "Hovorí po anglicky?", "Hovoríte po anglicky?", "Hovoria po anglicky?"],
          "answer": "Hovoríte po anglicky?",
          "answerMeaning": "Hovoríte = You speak (Vy form — formal/respectful). Use Vy when speaking to officials, officers, doctors, landlords, or anyone you don't know well."
        },
        {
          "situation": "You introduce yourself: 'I am from India and I am a doctor.' Which form of byť do you use for 'I am'?",
          "instruction": "Choose the correct form",
          "choices": ["Je", "Si", "Sme", "Som"],
          "answer": "Som",
          "answerMeaning": "Som = I am. Som z Indie a som doktor. Byť is the unique verb — Som is the Ja form you must remember."
        },
        {
          "situation": "You are filling in a form. It asks 'Kde bývate?' What is it asking?",
          "instruction": "Choose the correct meaning",
          "choices": [
            "Where do you work?",
            "Where do you live?",
            "Where are you from?",
            "Where are you going?"
          ],
          "answer": "Where do you live?",
          "answerMeaning": "Bývate = You live (Vy form — formal). Kde bývate? = Where do you live? One of the most common questions on Slovak official forms."
        }
      ]
    },
