    {
      "id": "ex4",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You are a tall man. What do you say about your height?",
          "instruction": "Choose the correct phrase",
          "choices": ["Som nízky.", "Som vysoký.", "Som vysoká.", "Som nízka."],
          "answer": "Som vysoký.",
          "answerMeaning": "Som vysoký = I am tall (male form). Slovak adjectives change ending based on gender."
        },
        {
          "situation": "You are a short woman. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["Som nízky.", "Som vysoká.", "Som nízka.", "Som vysoký."],
          "answer": "Som nízka.",
          "answerMeaning": "Som nízka = I am short (female form). Female form ends in -a."
        },
        {
          "situation": "The doctor's report says you are a man but you are a woman. How do you correct it?",
          "instruction": "Choose the correct phrase",
          "choices": ["Som muž.", "Som vysoká.", "Som žena.", "Som nízka."],
          "answer": "Som žena.",
          "answerMeaning": "Som žena = I am a woman. Medical records must be correct — always verify."
        },
        {
          "situation": "The police officer is writing a report about a missing person. You tell them the person is a tall Black man. Which two phrases do you use?",
          "instruction": "Choose the correct combination",
          "choices": [
            "Som vysoký. Som biely.",
            "Je vysoký. Je čierny.",
            "Som nízky. Som čierny.",
            "Je nízka. Je biela."
          ],
          "answer": "Je vysoký. Je čierny.",
          "answerMeaning": "Je = He/She is. Je vysoký = He is tall. Je čierny = He is Black. When describing someone else, use Je instead of Som."
        },
        {
          "situation": "You greet the police officer formally before giving your description. What do you say? (the Greetings lesson)",
          "instruction": "Choose the most appropriate greeting",
          "choices": ["Ahoj!", "Čau!", "Dobrý deň!", "Dobré ráno!"],
          "answer": "Dobrý deň!",
          "answerMeaning": "Dobrý deň = Good day — always formal in official settings. From the Greetings lesson."
        },
        {
          "situation": "After describing yourself to the officer they ask something you don't understand. What do you say?",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Ďakujem.", "Prepáčte.", "Nerozumiem.", "Dovidenia."],
          "answer": "Nerozumiem.",
          "answerMeaning": "Nerozumiem = I don't understand — from the I Don't Understand lesson. Always your first response when you miss something."
        }
      ]
    },
