    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You are looking at a flat to rent. You have a cat. What is the most important question to ask the landlord?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Ako sa volá?",
            "Sú povolené zvieratá?",
            "Mám psa.",
            "Kŕmiť?"
          ],
          "answer": "Sú povolené zvieratá?",
          "answerMeaning": "Sú povolené zvieratá? = Are pets allowed? Ask this before signing if you have a pet."
        },
        {
          "situation": "Your dog hasn't eaten yet today. What do you need to do?",
          "instruction": "Choose the correct word",
          "choices": [
            "Venčiť",
            "Kŕmiť",
            "Volá sa",
            "Veterinár"
          ],
          "answer": "Kŕmiť",
          "answerMeaning": "Kŕmiť = To feed."
        },
        {
          "situation": "Your dog needs its evening walk. What do you need to do?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Kŕmiť psa",
            "Venčiť psa",
            "Idem k veterinárovi.",
            "Mám zviera."
          ],
          "answer": "Venčiť psa",
          "answerMeaning": "Venčiť psa = To walk a dog."
        },
        {
          "situation": "Your cat is sick. Where do you need to take it?",
          "instruction": "Choose the correct word",
          "choices": [
            "Lekáreň",
            "Nemocnica",
            "Veterinár",
            "Recepcia"
          ],
          "answer": "Veterinár",
          "answerMeaning": "Veterinár = Vet. Animals go to the vet, not the hospital."
        },
        {
          "situation": "You are explaining that your cat is ill. Which phrase fits?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Mačka je chorá.",
            "Mačka je doma.",
            "Pes je veľký.",
            "Nemám zviera."
          ],
          "answer": "Mačka je chorá.",
          "answerMeaning": "Mačka je chorá. = The cat is sick."
        },
        {
          "situation": "You are leaving because the cat needs a vet. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Idem k veterinárovi.",
            "Idem do obchodu.",
            "Volá sa Rex.",
            "Sú povolené zvieratá?"
          ],
          "answer": "Idem k veterinárovi.",
          "answerMeaning": "Idem k veterinárovi. = I'm going to the vet."
        }
      ]
