    {
      "id": "ex6",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You have a headache and walk into the pharmacy. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Máte niečo na bolesť hlavy?",
            "Máte niečo na nádchu?",
            "Je potrebný predpis?",
            "Ako to mám užívať?"
          ],
          "answer": "Máte niečo na bolesť hlavy?",
          "answerMeaning": "Máte niečo na bolesť hlavy? = Do you have something for a headache? Bolesť hlavy combines bolesť (pain) and hlava (head) from the Head & Face and Hospital lessons."
        },
        {
          "situation": "The doctor gave you a prescription. The pharmacist asks if you have it. What do you show them?",
          "instruction": "Choose the correct word",
          "choices": ["Tabletky", "Predpis", "Masť", "Kvapky"],
          "answer": "Predpis",
          "answerMeaning": "Predpis = Prescription, from the Hospital lesson. Some medicines require this before the pharmacist can give them to you."
        },
        {
          "situation": "You want to know if you can buy something without a doctor's prescription. What do you ask?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Je potrebný predpis?",
            "Máte niečo na kašeľ?",
            "Dvakrát denne?",
            "Vedľajšie účinky?"
          ],
          "answer": "Je potrebný predpis?",
          "answerMeaning": "Je potrebný predpis? = Is a prescription needed? Important to ask before assuming you can just buy something."
        },
        {
          "situation": "You cut your finger and need something to cover it. What do you ask for?",
          "instruction": "Choose the correct word",
          "choices": ["Sirup", "Masť", "Náplasť", "Kvapky"],
          "answer": "Náplasť",
          "answerMeaning": "Náplasť = Plaster / Band-aid. Bolí ma prst (from the Arms & Legs lesson) — and now you know what to ask for."
        },
        {
          "situation": "The pharmacist hands you tablets and explains the instructions: 'Dvakrát denne, pred jedlom.' When and how often do you take them?",
          "instruction": "Choose the correct meaning",
          "choices": [
            "Once a day, after meals",
            "Twice a day, before meals",
            "Three times a day, after meals",
            "Once a week, before meals"
          ],
          "answer": "Twice a day, before meals",
          "answerMeaning": "Dvakrát denne = Twice a day. Pred jedlom = before meals. Always confirm timing instructions — getting this wrong can affect how well the medicine works."
        },
        {
          "situation": "You have a sore throat and a cough. Your child also has a cold. What do you ask the pharmacist for your child?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Máte niečo na nádchu?",
            "Máte niečo na bolesť hlavy?",
            "Je to voľne predajné?",
            "Vedľajšie účinky?"
          ],
          "answer": "Máte niečo na nádchu?",
          "answerMeaning": "Máte niečo na nádchu? = Do you have something for a cold? Nádcha = common cold/runny nose."
        },
        {
          "situation": "You want to know if a medicine has any unwanted reactions before taking it. What do you ask?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Aké sú vedľajšie účinky?",
            "Ako to mám užívať?",
            "Je to voľne predajné?",
            "Máte niečo na kašeľ?"
          ],
          "answer": "Aké sú vedľajšie účinky?",
          "answerMeaning": "Aké sú vedľajšie účinky? = What are the side effects? Important to ask, especially for new medicines."
        },
        {
          "situation": "You don't understand the pharmacist's instructions and need them explained again. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Ako to mám užívať?",
            "Nerozumiem. Môžete zopakovať?",
            "Máte niečo na nádchu?",
            "Dvakrát denne."
          ],
          "answer": "Nerozumiem. Môžete zopakovať?",
          "answerMeaning": "Nerozumiem. Môžete zopakovať? = I don't understand. Can you repeat that? From the I Don't Understand lesson — always useful when instructions matter for your health."
        }
      ]
    },
