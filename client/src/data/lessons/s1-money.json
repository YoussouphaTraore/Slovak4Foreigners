    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You pick up an item at a market stall. What is the first thing you ask the seller?",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Koľko to stojí?", "Platím kartou.", "Chcem zaplatiť.", "Zadarmo?"],
          "answer": "Koľko to stojí?",
          "answerMeaning": "How much does it cost? — the natural opening when buying anything."
        },
        {
          "situation": "The cashier asks 'Hotovosť alebo karta?' You want to pay by card.",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Platím v hotovosti.", "Platím kartou.", "Chcem drobné.", "Koľko to stojí?"],
          "answer": "Platím kartou.",
          "answerMeaning": "I'm paying by card. — you'll hear 'Hotovosť alebo karta?' at every checkout."
        },
        {
          "situation": "You hand a €5 note for a €2.50 coffee. The barista owes you coins. What do you ask for?",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Účtenku", "Kartu", "Drobné", "Cenu"],
          "answer": "Drobné",
          "answerMeaning": "Small change / Coins — drobné literally means 'small ones'."
        },
        {
          "situation": "You're expensing a business lunch and need proof of purchase. What do you ask before leaving?",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Koľko to stojí?", "Môžem dostať účtenku?", "Platím v hotovosti.", "Chcem drobné."],
          "answer": "Môžem dostať účtenku?",
          "answerMeaning": "Can I get a receipt? — essential for work expenses."
        },
        {
          "situation": "The price tag reads 15 eur. How much is the item?",
          "instruction": "Choose the correct amount",
          "choices": ["5 eur", "14 eur", "15 eur", "50 eur"],
          "answer": "15 eur",
          "answerMeaning": "pätnásť = fifteen — from the Cardinal Numbers lesson."
        },
        {
          "situation": "You have only a 20 eur note. The item costs exactly 20 eur. What is ideal about this situation?",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Platím kartou.", "Máte drobné?", "Platím v hotovosti. Presná suma.", "Môžem dostať účtenku?"],
          "answer": "Platím v hotovosti. Presná suma.",
          "answerMeaning": "I'm paying in cash. Exact amount. — no change needed!"
        },
        {
          "situation": "You see a sign in a museum that says 'Vstup zadarmo.' What does it mean?",
          "instruction": "Choose the correct meaning",
          "choices": ["Entry costs money", "Entry is free", "Entry needs a card", "Entry needs cash"],
          "answer": "Entry is free",
          "answerMeaning": "Vstup zadarmo = Entry is free. Zadarmo = free of charge — great word to recognise on signs."
        },
        {
          "situation": "At a restaurant you ask for the bill. What do you say?",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Môžem dostať účet?", "Máte drobné?", "Chcem peniaze.", "Koľko to stojí?"],
          "answer": "Môžem dostať účet?",
          "answerMeaning": "Môžem dostať účet? = Can I get the bill? Účet = bill (different from účtenka = receipt)."
        }
      ]
    },
