    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "Kai is speaking as a man and says he was at home yesterday. Which phrase fits?",
          "instruction": "Choose the male-speaker form",
          "choices": [
            "Bol som doma.",
            "Bola som doma.",
            "Bude doma.",
            "Som doma."
          ],
          "answer": "Bol som doma.",
          "answerMeaning": "Bol som doma. = I was at home, said by a male speaker."
        },
        {
          "situation": "Kai is speaking as a woman and says she was at home yesterday. Which phrase fits?",
          "instruction": "Choose the female-speaker form",
          "choices": [
            "Bola som doma.",
            "Bol som doma.",
            "Bude doma.",
            "Som doma."
          ],
          "answer": "Bola som doma.",
          "answerMeaning": "Bola som doma. = I was at home, said by a female speaker."
        },
        {
          "situation": "A male speaker tells the doctor he was sick. Which phrase is correct?",
          "instruction": "Choose the male-speaker form",
          "choices": [
            "Bol som chorý.",
            "Bola som chorá.",
            "Bude pršať.",
            "Je mi dobre."
          ],
          "answer": "Bol som chorý.",
          "answerMeaning": "Bol som chorý. = I was sick, said by a male speaker."
        },
        {
          "situation": "A female speaker tells the doctor she was sick. Which phrase is correct?",
          "instruction": "Choose the female-speaker form",
          "choices": [
            "Bola som chorá.",
