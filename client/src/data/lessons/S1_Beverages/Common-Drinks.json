    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You want plain water. Which word do you need?",
          "instruction": "Choose the correct word",
          "choices": [
            "Voda",
            "Káva",
            "Čaj",
            "Pivo"
          ],
          "answer": "Voda",
          "answerMeaning": "Voda = Water."
        },
        {
          "situation": "You want coffee in the morning. Which word fits?",
          "instruction": "Choose the correct word",
          "choices": [
            "Káva",
            "Čaj",
            "Mlieko",
            "Džús"
          ],
          "answer": "Káva",
          "answerMeaning": "Káva = Coffee."
        },
        {
          "situation": "Someone offers tea. Which Slovak word means tea?",
          "instruction": "Choose the correct word",
          "choices": [
            "Čaj",
            "Káva",
            "Pivo",
            "Voda"
          ],
          "answer": "Čaj",
          "answerMeaning": "Čaj = Tea."
        },
        {
          "situation": "You need milk for coffee. Which word means milk?",
          "instruction": "Choose the correct word",
          "choices": [
            "Mlieko",
            "Džús",
            "Voda",
            "Pivo"
          ],
          "answer": "Mlieko",
          "answerMeaning": "Mlieko = Milk."
        },
        {
          "situation": "You want orange juice. Which word means juice?",
          "instruction": "Choose the correct word",
          "choices": [
            "Džús",
            "Čaj",
            "Mlieko",
            "Káva"
          ],
          "answer": "Džús",
          "answerMeaning": "Džús = Juice."
        },
        {
          "situation": "Your colleagues invite you for an evening drink after work. Which Slovak drink might they suggest?",
          "instruction": "Choose the most likely word",
          "choices": [
            "Mlieko",
            "Pivo",
            "Čaj",
            "Voda"
          ],
          "answer": "Pivo",
          "answerMeaning": "Pivo = Beer. It is common for after-work socializing."
        }
      ]
    },
