    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You arrive at reception and have an appointment. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Som objednaný.",
            "Bez objednania.",
            "Je mi zle.",
            "Čakáreň."
          ],
          "answer": "Som objednaný.",
          "answerMeaning": "Som objednaný = I have an appointment. Som objednaná for female."
        },
        {
          "situation": "You do not have an appointment but need to see a doctor urgently. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Som bez objednania, je to urgentné.",
            "Som objednaný.",
            "Karta poistenca.",
            "Dvakrát denne."
          ],
          "answer": "Som bez objednania, je to urgentné.",
          "answerMeaning": "Bez objednania = without appointment."
        },
        {
          "situation": "The receptionist asks for your health insurance details. What do you hand over?",
          "instruction": "Choose the correct item",
          "choices": [
            "Karta poistenca",
            "Predpis",
            "Náplasť",
            "Tabletky"
          ],
          "answer": "Karta poistenca",
          "answerMeaning": "Karta poistenca = insurance card."
        },
        {
          "situation": "You are waiting to be called before your appointment. Where are you?",
          "instruction": "Choose the correct word",
          "choices": [
            "Čakáreň",
            "Recepcia",
            "Urgentný príjem",
            "Lekáreň"
          ],
          "answer": "Čakáreň",
          "answerMeaning": "Čakáreň = waiting room."
        },
        {
          "situation": "It is serious and life-threatening, not a regular appointment. Where do you go?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Urgentný príjem",
            "Čakáreň",
            "Recepcia",
            "Karta poistenca"
          ],
          "answer": "Urgentný príjem",
          "answerMeaning": "Urgentný príjem = emergency room / A&E."
        }
      ]
    },
