    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "The pharmacist gives you tabletky. What did you receive?",
          "instruction": "Choose the meaning",
          "choices": [
            "Pills",
            "Drops",
            "Syrup",
            "Plaster"
          ],
          "answer": "Pills",
          "answerMeaning": "Tabletky = pills."
        },
        {
          "situation": "You cut your finger and need something to cover it. What do you ask for?",
          "instruction": "Choose the correct word",
          "choices": [
            "Náplasť",
            "Sirup",
            "Kvapky",
            "Masť"
          ],
          "answer": "Náplasť",
          "answerMeaning": "Náplasť = plaster / band-aid."
        },
        {
          "situation": "You need liquid medicine for a cough. Which word is syrup?",
          "instruction": "Choose the correct word",
          "choices": [
            "Sirup",
            "Tabletky",
            "Masť",
            "Náplasť"
          ],
          "answer": "Sirup",
          "answerMeaning": "Sirup = syrup."
        },
        {
          "situation": "You need cream for your skin. Which word means ointment?",
          "instruction": "Choose the correct word",
          "choices": [
            "Masť",
            "Kvapky",
            "Lieky",
            "Predpis"
          ],
          "answer": "Masť",
          "answerMeaning": "Masť = ointment."
        },
        {
          "situation": "The doctor recommends drops. Which word do you look for?",
          "instruction": "Choose the correct word",
          "choices": [
            "Kvapky",
            "Tabletky",
            "Náplasť",
            "Sirup"
          ],
          "answer": "Kvapky",
          "answerMeaning": "Kvapky = drops."
        }
      ]
    },
