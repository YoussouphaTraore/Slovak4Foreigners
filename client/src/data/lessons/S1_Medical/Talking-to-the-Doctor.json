    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "The doctor asks: Čo vás trápi? What do they want to know?",
          "instruction": "Choose the meaning",
          "choices": [
            "What's wrong?",
            "Where do you live?",
            "How much is it?",
            "What is your name?"
          ],
          "answer": "What's wrong?",
          "answerMeaning": "Čo vás trápi? = What's troubling you?"
        },
        {
          "situation": "The doctor asks how long this has been going on. Which phrase did they use?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Ako dlho to trvá?",
            "Čo vás trápi?",
            "Kde je lekáreň?",
            "Je potrebný predpis?"
          ],
          "answer": "Ako dlho to trvá?",
          "answerMeaning": "Ako dlho to trvá? = How long has this been going on?"
        },
        {
          "situation": "Your symptoms started yesterday. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Od včera.",
            "Zajtra.",
            "Dvakrát denne.",
            "Som objednaný."
          ],
          "answer": "Od včera.",
          "answerMeaning": "Od včera. = Since yesterday."
        },
        {
          "situation": "The doctor gives you a paper for the pharmacy. What is it called?",
          "instruction": "Choose the correct word",
          "choices": [
            "Predpis",
            "Čakáreň",
            "Karta poistenca",
            "Recepcia"
          ],
          "answer": "Predpis",
          "answerMeaning": "Predpis = prescription."
        },
        {
          "situation": "The doctor says: Berte tento liek. What should you do?",
          "instruction": "Choose the meaning",
          "choices": [
            "Take this medicine.",
            "Show your card.",
            "Wait here.",
            "Call police."
          ],
          "answer": "Take this medicine.",
          "answerMeaning": "Berte tento liek. = Take this medicine."
        }
      ]
    },
