    {
      "id": "ex6",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "Your fridge stops cooling. What do you tell your landlord?",
          "instruction": "Choose the correct phrase",
          "choices": ["Práčka nefunguje.", "Chladnička nefunguje.", "Posteľ nefunguje.", "Skriňa nefunguje."],
          "answer": "Chladnička nefunguje.",
          "answerMeaning": "Chladnička nefunguje = The fridge doesn't work. Nefunguje is the key phrase for reporting any broken appliance."
        },
        {
          "situation": "Your washing machine is leaking water. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["Práčka sa pokazila.", "Posteľ sa pokazila.", "Kuchyňa sa pokazila.", "Stolička sa pokazila."],
          "answer": "Práčka sa pokazila.",
          "answerMeaning": "Práčka sa pokazila = The washing machine broke. Sa pokazila is the feminine past form — práčka is a feminine noun."
        },
        {
          "situation": "You want the landlord to come see the problem in person. What do you ask?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Môžete prísť a pozrieť sa?",
            "Potrebujem opraviť posteľ.",
            "Kde je kúpeľňa?",
            "Stôl pre dvoch."
          ],
          "answer": "Môžete prísť a pozrieť sa?",
          "answerMeaning": "Môžete prísť a pozrieť sa? = Can you come and look? Useful when you can't describe the problem clearly over the phone."
        },
        {
          "situation": "You want to host a guest and show them around. Where do you say you usually relax and watch TV?",
          "instruction": "Choose the correct word",
          "choices": ["Spálňa", "Kúpeľňa", "Obývačka", "Kuchyňa"],
          "answer": "Obývačka",
          "answerMeaning": "Obývačka = Living room. The room for relaxing, watching TV, and spending time with guests."
        },
        {
          "situation": "Where do you say you sleep at night?",
          "instruction": "Choose the correct word",
          "choices": ["Obývačka", "Spálňa", "Kuchyňa", "Kúpeľňa"],
          "answer": "Spálňa",
          "answerMeaning": "Spálňa = Bedroom. From spať (to sleep) — the room where you rest."
        },
        {
          "situation": "Your wardrobe door fell off. What do you say you need to do?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Potrebujem opraviť skriňu.",
            "Potrebujem opraviť kuchyňu.",
            "Potrebujem opraviť spálňu.",
            "Potrebujem opraviť obývačku."
          ],
          "answer": "Potrebujem opraviť skriňu.",
          "answerMeaning": "Potrebujem opraviť skriňu = I need to fix the wardrobe. Skriňa = wardrobe/cabinet."
        },
        {
          "situation": "You're cooking dinner. Which room are you in?",
          "instruction": "Choose the correct word",
          "choices": ["Kúpeľňa", "Spálňa", "Kuchyňa", "Obývačka"],
          "answer": "Kuchyňa",
          "answerMeaning": "Kuchyňa = Kitchen. Where you cook and often eat your meals at home."
        },
        {
          "situation": "Your shower stopped producing hot water. Where is the problem located?",
          "instruction": "Choose the correct word",
          "choices": ["Kuchyňa", "Spálňa", "Kúpeľňa", "Obývačka"],
          "answer": "Kúpeľňa",
          "answerMeaning": "Kúpeľňa = Bathroom. From kúpeľ (bath) — the room with the shower, sink and toilet."
        }
      ]
    },
