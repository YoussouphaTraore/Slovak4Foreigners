    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You want to confirm a meeting for tomorrow. What word do you use?",
          "instruction": "Choose the correct word",
          "choices": [
            "Dnes",
            "Zajtra",
            "Včera",
            "Víkend"
          ],
          "answer": "Zajtra",
          "answerMeaning": "Zajtra = tomorrow."
        },
        {
          "situation": "You missed a delivery yesterday. Which word do you need?",
          "instruction": "Choose the correct word",
          "choices": [
            "Dnes",
            "Zajtra",
            "Včera",
            "Pondelok"
          ],
          "answer": "Včera",
          "answerMeaning": "Včera = yesterday."
        },
        {
          "situation": "Your colleague asks what day it is today. Which word means today?",
          "instruction": "Choose the correct word",
          "choices": [
            "Dnes",
            "Zajtra",
            "Včera",
            "Týždeň"
          ],
          "answer": "Dnes",
          "answerMeaning": "Dnes = today."
        },
        {
          "situation": "You work Monday to Friday. How do you describe this routine?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Každý víkend",
            "Každý pracovný deň",
            "Každú nedeľu",
            "Zajtra"
          ],
          "answer": "Každý pracovný deň",
          "answerMeaning": "Každý pracovný deň = every working day."
        },
        {
          "situation": "You need to do something this week, not next week. Which phrase fits?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Tento týždeň",
            "Minulý týždeň",
            "Budúci týždeň",
            "Včera"
          ],
          "answer": "Tento týždeň",
          "answerMeaning": "Tento týždeň = this week."
        }
      ]
    },
    {
