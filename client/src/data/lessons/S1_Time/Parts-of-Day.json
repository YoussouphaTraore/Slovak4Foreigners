    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You greet your colleague at 7am. Which phrase fits?",
          "instruction": "Choose the best answer",
          "choices": [
            "Dobré ráno",
            "Dobrý večer",
            "Dobrú noc",
            "Dobrý deň"
          ],
          "answer": "Dobré ráno",
          "answerMeaning": "Dobré ráno = Good morning. Ráno = morning."
        },
        {
          "situation": "You are leaving a friend very late and they are going to sleep. Which phrase fits?",
          "instruction": "Choose the best answer",
          "choices": [
            "Dobré ráno",
            "Dobrú noc",
            "Dobrý deň",
            "Ahoj ráno"
          ],
          "answer": "Dobrú noc",
          "answerMeaning": "Dobrú noc = Good night."
        },
        {
          "situation": "A meeting is exactly in the middle of the day. Which word means noon?",
          "instruction": "Choose the correct word",
          "choices": [
            "Ráno",
            "Poludnie",
            "Večer",
            "Polnoc"
          ],
          "answer": "Poludnie",
          "answerMeaning": "Poludnie = noon / midday."
        },
        {
          "situation": "A bus leaves at midnight. Which word means midnight?",
          "instruction": "Choose the correct word",
          "choices": [
            "Polnoc",
            "Popoludnie",
            "Ráno",
            "Večer"
          ],
          "answer": "Polnoc",
          "answerMeaning": "Polnoc = midnight."
        },
        {
          "situation": "The shop closes in the evening. Which word means evening?",
          "instruction": "Choose the correct word",
          "choices": [
            "Ráno",
            "Večer",
            "Noc",
            "Poludnie"
          ],
          "answer": "Večer",
          "answerMeaning": "Večer = evening."
        }
      ]
    },
