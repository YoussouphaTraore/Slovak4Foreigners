    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You want to know what time it is right now. What do you ask?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "O koľkej?",
            "Koľko je hodín?",
            "Aký je deň?",
            "Kedy?"
          ],
          "answer": "Koľko je hodín?",
          "answerMeaning": "Koľko je hodín? = What time is it?"
        },
        {
          "situation": "You want to know what time your appointment is. What do you ask?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Koľko je hodín?",
            "O koľkej?",
            "Kde je to?",
            "Koľko to stojí?"
          ],
          "answer": "O koľkej?",
          "answerMeaning": "O koľkej? = At what time?"
        },
        {
          "situation": "Your doctor appointment is at 10am. How do you say this?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Je desiata.",
            "O desiatej.",
            "Desať hodín.",
            "Pol desiatej."
          ],
          "answer": "O desiatej.",
          "answerMeaning": "O desiatej = At ten o'clock."
        },
        {
          "situation": "Someone asks 'Koľko je hodín?' and it is exactly five o'clock. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "O piatej.",
            "Je päť hodín.",
            "Päť minút.",
            "Pol piatej."
          ],
          "answer": "Je päť hodín.",
          "answerMeaning": "Je päť hodín = It is five o'clock."
        },
        {
          "situation": "A shop sign says it opens 'o ôsmej ráno.' What time does it open?",
          "instruction": "Choose the correct time",
          "choices": [
            "8pm",
            "8am",
            "10am",
            "Noon"
          ],
          "answer": "8am",
          "answerMeaning": "O ôsmej ráno = at eight in the morning."
        },
        {
          "situation": "You want to say your meeting is at half past two. What key word do you need?",
          "instruction": "Choose the correct word",
          "choices": [
            "Hodina",
            "Minúta",
            "Pol",
            "Noc"
          ],
          "answer": "Pol",
          "answerMeaning": "Pol = half past."
        }
      ]
