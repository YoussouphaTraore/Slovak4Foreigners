    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You fell and hurt your leg. You are at the emergency room. Which word do you use?",
          "instruction": "Choose the correct word",
          "choices": [
            "Ruka",
            "Koleno",
            "Noha",
            "Plece"
          ],
          "answer": "Noha",
          "answerMeaning": "Noha = Leg / foot. Bolí ma noha = My leg hurts. Slovak uses noha for both leg and foot."
        },
        {
          "situation": "You twisted your knee playing sport. At the doctor you say \"Bolí ma...\" and point. Which word completes the sentence?",
          "instruction": "Choose the correct word",
          "choices": [
            "Noha",
            "Prst",
            "Koleno",
            "Ruka"
          ],
          "answer": "Koleno",
          "answerMeaning": "Koleno = Knee. Bolí ma koleno = My knee hurts. The phrase Bolí ma + body part is useful in any clinic."
        },
        {
          "situation": "You cut your finger while cooking. At the pharmacy you show them and say \"Bolí ma...\" Which word do you use?",
          "instruction": "Choose the correct word",
          "choices": [
            "Ruka",
            "Noha",
            "Koleno",
            "Prst"
          ],
          "answer": "Prst",
          "answerMeaning": "Prst = Finger / toe. Context makes it clear whether you mean a finger or a toe."
        },
        {
          "situation": "You slipped and landed on your arm. Which word helps you explain what hurts?",
          "instruction": "Choose the correct word",
          "choices": [
            "Ruka",
            "Zuby",
            "Hruď",
            "Vlasy"
          ],
          "answer": "Ruka",
          "answerMeaning": "Ruka = Hand / arm. Slovak uses one common word for hand and arm."
        }
      ]
    },
