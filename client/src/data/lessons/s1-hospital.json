    {
      "id": "ex6",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You arrive at the hospital and the receptionist asks if you have an appointment. You do. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["Bez objednania.", "Som objednaný.", "Je mi zle.", "Čo vás trápi?"],
          "answer": "Som objednaný.",
          "answerMeaning": "Som objednaný = I have an appointment (male). Som objednaná for female. The receptionist needs this to check you in correctly."
        },
        {
          "situation": "You don't have an appointment but need to see a doctor urgently. What do you tell the receptionist?",
          "instruction": "Choose the correct phrase",
          "choices": ["Som objednaný.", "Som bez objednania, je to urgentné.", "Karta poistenca.", "Čakáreň, prosím."],
          "answer": "Som bez objednania, je to urgentné.",
          "answerMeaning": "Som bez objednania, je to urgentné = I don't have an appointment, it's urgent. Important phrase when you need to be seen without a booking."
        },
        {
          "situation": "The receptionist asks for your health insurance details. What do you hand over?",
          "instruction": "Choose the correct item",
          "choices": ["Predpis", "Karta poistenca", "Čakáreň", "Recepcia"],
          "answer": "Karta poistenca",
          "answerMeaning": "Karta poistenca = Insurance card. Always carry this with you for any medical visit in Slovakia."
        },
        {
          "situation": "You've had a fever and cough since yesterday. The doctor asks how long. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["Čo vás trápi?", "Berte tento liek.", "Od včera.", "Karta poistenca."],
          "answer": "Od včera.",
          "answerMeaning": "Od včera = Since yesterday. Od + time period, from the Months of the Year lesson logic (Od marca = since March)."
        },
        {
          "situation": "The doctor asks 'Čo vás trápi?' You have a headache and feel dizzy. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Bolí ma hlava a mám závrat.",
            "Som objednaný.",
            "Karta poistenca.",
            "Berte tento liek."
          ],
          "answer": "Bolí ma hlava a mám závrat.",
          "answerMeaning": "Bolí ma hlava a mám závrat = My head hurts and I have dizziness. Bolí ma + body part (Parts of the Body lesson) + mám + symptom."
        },
        {
          "situation": "After examining you, the doctor hands you a piece of paper for the pharmacy. What is this called?",
          "instruction": "Choose the correct word",
          "choices": ["Karta poistenca", "Čakáreň", "Predpis", "Recepcia"],
          "answer": "Predpis",
          "answerMeaning": "Predpis = Prescription. You will take this to the pharmacy (lekáreň) to get your medicine."
        },
        {
          "situation": "It's a life-threatening situation, not a regular appointment. Which part of the hospital do you go to?",
          "instruction": "Choose the correct phrase",
          "choices": ["Čakáreň", "Recepcia", "Urgentný príjem", "Karta poistenca"],
          "answer": "Urgentný príjem",
          "answerMeaning": "Urgentný príjem = Emergency room / A&E. Different from a scheduled appointment — go straight here for serious emergencies."
        },
        {
          "situation": "You're sitting before your appointment, waiting to be called. Where are you?",
          "instruction": "Choose the correct word",
          "choices": ["Čakáreň", "Recepcia", "Urgentný príjem", "Predpis"],
          "answer": "Čakáreň",
          "answerMeaning": "Čakáreň = Waiting room. From čakať (to wait) — you'll spend time here before most appointments."
        }
      ]
    },
