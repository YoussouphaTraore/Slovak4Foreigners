          "choices": [
            "Above the restaurant",
            "Below the restaurant",
            "Next to the restaurant",
            "Behind the restaurant"
          ],
          "answer": "Above the restaurant",
          "answerMeaning": "Nad = above / over."
        },
        {
          "situation": "Your colleague says the storage room is pod schodmi. Where should you look?",
          "instruction": "Choose the correct location",
          "choices": [
            "Under the stairs",
            "Above the stairs",
            "Opposite the stairs",
            "Next to the bank"
          ],
          "answer": "Under the stairs",
          "answerMeaning": "Pod schodmi = under the stairs."
        },
        {
          "situation": "The police ask your exact location. You are between the pharmacy and the post office. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Som medzi lekárňou a poštou.",
            "Som nad reštauráciou.",
            "Som pod schodmi.",
            "Som za bankou."
          ],
          "answer": "Som medzi lekárňou a poštou.",
          "answerMeaning": "Medzi = between."
        },
        {
          "situation": "Which word means below or under?",
          "instruction": "Choose the correct word",
          "choices": [
            "Pod",
