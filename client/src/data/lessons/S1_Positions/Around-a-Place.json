    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "Your friend texts: Čakám pred nemocnicou. Where are they waiting?",
          "instruction": "Choose the correct location",
          "choices": [
            "In front of the hospital",
            "Behind the hospital",
            "Inside the hospital",
            "Above the hospital"
          ],
          "answer": "In front of the hospital",
          "answerMeaning": "Pred nemocnicou = in front of the hospital."
        },
        {
          "situation": "You want to meet at the café directly across from the bank. Which phrase means opposite the bank?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Naproti banke",
            "Vedľa banky",
            "Pred bankou",
            "Za bankou"
          ],
          "answer": "Naproti banke",
          "answerMeaning": "Naproti = opposite / across from."
        },
        {
          "situation": "You call emergency services and are right next to the pharmacy. What do you say?",
          "instruction": "Choose the most precise phrase",
          "choices": [
            "Som pri lekárni.",
            "Som za lekárňou.",
            "Som nad lekárňou.",
            "Som vnútri lekárne."
          ],
          "answer": "Som pri lekárni.",
          "answerMeaning": "Pri = at / right next to. Som pri lekárni = I am right by the pharmacy."
        },
        {
          "situation": "You walked past the café entrance and are now behind it. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Som za kaviarňou.",
            "Som pred kaviarňou.",
            "Som pri lekárni.",
            "Som naproti banke."
          ],
          "answer": "Som za kaviarňou.",
          "answerMeaning": "Za = behind / past."
        },
        {
          "situation": "The police station is next to the hospital. Which word means next to?",
          "instruction": "Choose the correct word",
          "choices": [
            "Vedľa",
            "Naproti",
            "Pred",
            "Za"
          ],
          "answer": "Vedľa",
          "answerMeaning": "Vedľa = next to / beside."
        }
      ]
    },
