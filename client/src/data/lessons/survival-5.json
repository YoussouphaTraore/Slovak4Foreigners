    {
      "id": "ex8",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You pick up an item at a market stall. What is the first thing you ask the seller?",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Koľko to stojí?",
            "Platím kartou.",
            "Chcem zaplatiť.",
            "Zadarmo?"
          ],
          "answer": "Koľko to stojí?",
          "answerMeaning": "How much does it cost? — the natural opening when buying anything"
        },
        {
          "situation": "The cashier asks 'Hotovosť alebo karta?' (Cash or card?). You want to pay by card.",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Platím v hotovosti.",
            "Platím kartou.",
            "Chcem drobné.",
            "Koľko to stojí?"
          ],
          "answer": "Platím kartou.",
          "answerMeaning": "I'm paying by card. — you'll hear 'Hotovosť alebo karta?' at every checkout"
        },
        {
          "situation": "You hand a €20 note for a €3 coffee. The barista owes you coins. What do you ask for?",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Účtenku",
            "Kartu",
            "Drobné",
            "Cenu"
          ],
          "answer": "Drobné",
          "answerMeaning": "Small change / Coins — drobné literally means 'small ones'"
        },
        {
          "situation": "You're expensing a business lunch and need proof of purchase. What do you ask before leaving?",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Koľko to stojí?",
            "Môžem dostať účtenku?",
            "Platím v hotovosti.",
            "Chcem drobné."
          ],
          "answer": "Môžem dostať účtenku?",
          "answerMeaning": "Can I get a receipt? — essential for work expenses"
        },
        {
          "situation": "The price tag reads 'pätnásť eur'. How much is the item?",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "€5",
            "€14",
            "€15",
            "€50"
          ],
          "answer": "€15",
          "answerMeaning": "pätnásť = fifteen — päť (5) + násť (teen suffix)"
        },
        {
          "situation": "The display shows 'dvanásť eur'. You know this word — it appears in the emergency number 112 (sto dvanásť). How much is it?",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "€11",
            "€12",
            "€20",
            "€22"
          ],
          "answer": "€12",
          "answerMeaning": "dvanásť = twelve — the same word you learned in Lesson 4 for 1-1-2 (sto dvanásť)!"
        },
        {
          "situation": "You are at a pharmacy and feel unwell. What do you tell the pharmacist? (from Lesson 3)",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Je mi dobre.",
            "Je mi zle.",
            "Koľko to stojí?",
            "Zadarmo!"
          ],
          "answer": "Je mi zle.",
          "answerMeaning": "I feel unwell. (from Lesson 3 — very useful when explaining why you need medicine!)"
        },
        {
          "situation": "You have only a €20 note. The item costs dvadsať eur. What is ideal about this situation?",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Platím kartou.",
            "Máte drobné?",
            "Platím v hotovosti. Presná suma.",
            "Môžem dostať účtenku?"
          ],
          "answer": "Platím v hotovosti. Presná suma.",
          "answerMeaning": "I'm paying in cash. Exact amount. — dvadsať = twenty, no change needed!"
        }
      ]
    },
