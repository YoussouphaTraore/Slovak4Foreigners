    {
      "id": "ex6",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You only need to take the tram once today. What kind of ticket do you buy?",
          "instruction": "Choose the correct phrase",
          "choices": ["Predplatná karta", "Jednorazový lístok", "Kontrola lístkov", "Smer centrum"],
          "answer": "Jednorazový lístok",
          "answerMeaning": "Jednorazový lístok = Single ticket. The right choice for a one-time trip rather than a longer pass."
        },
        {
          "situation": "You use public transport every day. What should you get instead of buying single tickets each time?",
          "instruction": "Choose the correct phrase",
          "choices": ["Jednorazový lístok", "Kontrola lístkov", "Predplatná karta", "Ďalšia zastávka"],
          "answer": "Predplatná karta",
          "answerMeaning": "Predplatná karta = Travel pass/card. Much cheaper than buying single tickets if you travel often."
        },
        {
          "situation": "You board the bus with a paper ticket. What must you do immediately?",
          "instruction": "Choose the correct phrase",
          "choices": ["Tu vystupujem.", "Validovať lístok.", "Kde mám vystúpiť?", "Smer centrum."],
          "answer": "Validovať lístok.",
          "answerMeaning": "Validovať lístok = Validate the ticket. In most Slovak cities you must stamp/validate your ticket in a machine right after boarding."
        },
        {
          "situation": "An inspector boards and starts checking everyone's tickets. What is this called?",
          "instruction": "Choose the correct phrase",
          "choices": ["Kontrola lístkov", "Ďalšia zastávka", "Jednorazový lístok", "Smer centrum"],
          "answer": "Kontrola lístkov",
          "answerMeaning": "Kontrola lístkov = Ticket check. Always validate your ticket — this happens regularly, especially in Bratislava."
        },
        {
          "situation": "You don't know your stop and want the driver or a passenger to tell you when to get off. What do you ask?",
          "instruction": "Choose the correct phrase",
          "choices": ["Tu vystupujem.", "Kde mám vystúpiť?", "Ide toto do centra?", "Smer centrum."],
          "answer": "Kde mám vystúpiť?",
          "answerMeaning": "Kde mám vystúpiť? = Where should I get off? Useful when you're unsure of your stop."
        },
        {
          "situation": "Your stop is approaching. You need to move toward the door past other passengers. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["Tu vystupujem.", "Prepáčte, môžem prejsť?", "Kedy ide ďalší autobus?", "Validovať lístok."],
          "answer": "Prepáčte, môžem prejsť?",
          "answerMeaning": "Prepáčte, môžem prejsť? = Excuse me, may I pass? Polite way to move through a crowded bus or tram."
        },
        {
          "situation": "It's your stop right now. What do you say as you step off?",
          "instruction": "Choose the correct phrase",
          "choices": ["Kde mám vystúpiť?", "Tu vystupujem.", "Ide toto do centra?", "Kontrola lístkov."],
          "answer": "Tu vystupujem.",
          "answerMeaning": "Tu vystupujem = I'm getting off here. Useful to say to the driver on smaller buses where you signal your stop."
        },
        {
          "situation": "You're not sure if the tram in front of you goes downtown. What do you ask?",
          "instruction": "Choose the correct phrase",
          "choices": ["Ide toto do centra?", "Kde mám vystúpiť?", "Tu vystupujem.", "Validovať lístok."],
          "answer": "Ide toto do centra?",
          "answerMeaning": "Ide toto do centra? = Does this go to the centre? Always confirm before boarding if you're unsure."
        }
      ]
