    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "Your landlord asks when you pay rent. You pay it every month. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["Platím každý týždeň.", "Platím každý mesiac.", "Platím zajtra.", "Platím v piatok."],
          "answer": "Platím každý mesiac.",
          "answerMeaning": "Platím každý mesiac = I pay every month. Mesiac = month, from this lesson."
        },
        {
          "situation": "Your colleague asks if the team meeting was last week. It was. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["Schôdza bola budúci týždeň.", "Schôdza bola minulý týždeň.", "Schôdza bola tento mesiac.", "Schôdza je zajtra."],
          "answer": "Schôdza bola minulý týždeň.",
          "answerMeaning": "Schôdza bola minulý týždeň = The meeting was last week. Minulý týždeň = last week."
        },
        {
          "situation": "You are asked when your next dentist appointment is. It is next week. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["Je budúci týždeň.", "Je minulý týždeň.", "Je každý mesiac.", "Je dnes."],
          "answer": "Je budúci týždeň.",
          "answerMeaning": "Je budúci týždeň = It is next week. Budúci týždeň = next week."
        },
        {
          "situation": "You go to the gym every week without exception. How do you describe this habit?",
          "instruction": "Choose the correct phrase",
          "choices": ["Idem tento týždeň.", "Idem každý týždeň.", "Idem budúci týždeň.", "Idem minulý týždeň."],
          "answer": "Idem každý týždeň.",
          "answerMeaning": "Idem každý týždeň = I go every week. Každý týždeň = every week."
        },
        {
          "situation": "Your salary is paid on the first week of every month. How do you describe this?",
          "instruction": "Choose the correct phrase",
          "choices": ["Platia mi posledný týždeň.", "Platia mi prvý týždeň mesiaca.", "Platia mi minulý týždeň.", "Platia mi každý deň."],
          "answer": "Platia mi prvý týždeň mesiaca.",
          "answerMeaning": "Platia mi prvý týždeň mesiaca = I get paid the first week of the month. Prvý = first, from the Cardinal & Ordinal Numbers lesson."
        },
        {
          "situation": "Your rent is due during the last week of the month. How do you say this?",
          "instruction": "Choose the correct phrase",
          "choices": ["Nájom je prvý týždeň mesiaca.", "Nájom je posledný týždeň mesiaca.", "Nájom je každý mesiac.", "Nájom je budúci mesiac."],
          "answer": "Nájom je posledný týždeň mesiaca.",
          "answerMeaning": "Nájom je posledný týždeň mesiaca = Rent is due the last week of the month. Posledný = last."
        }
      ]
    },
