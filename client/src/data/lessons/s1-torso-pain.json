    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You have chest pain and call 155. Which word tells the dispatcher where the pain is?",
          "instruction": "Choose the correct word",
          "choices": [
            "Chrbát",
            "Brucho",
            "Hruď",
            "Plece"
          ],
          "answer": "Hruď",
          "answerMeaning": "Hruď = Chest. Bolí ma hruď = My chest hurts. Chest pain is a 155 call, so say this clearly."
        },
        {
          "situation": "You hurt your back carrying boxes. What do you tell your doctor?",
          "instruction": "Choose the correct word",
          "choices": [
            "Brucho",
            "Srdce",
            "Hruď",
            "Chrbát"
          ],
          "answer": "Chrbát",
          "answerMeaning": "Chrbát = Back. Bolí ma chrbát = My back hurts. This is a common complaint at Slovak GP offices."
        },
        {
          "situation": "You ate something bad and now your stomach hurts. Which word do you need?",
          "instruction": "Choose the correct word",
          "choices": [
            "Brucho",
            "Plece",
            "Srdce",
            "Hruď"
          ],
          "answer": "Brucho",
          "answerMeaning": "Brucho = Stomach / belly. Bolí ma brucho = My stomach hurts."
        },
        {
          "situation": "You fell on the ice and your shoulder hurts. Which word do you use?",
          "instruction": "Choose the correct word",
          "choices": [
            "Plece",
            "Srdce",
            "Brucho",
            "Chrbát"
          ],
          "answer": "Plece",
          "answerMeaning": "Plece = Shoulder. Bolí ma plece = My shoulder hurts."
        },
        {
          "situation": "A doctor asks if the pain is in your chest or your heart. Which Slovak word means heart?",
          "instruction": "Choose the correct word",
          "choices": [
            "Hruď",
            "Srdce",
            "Chrbát",
            "Brucho"
          ],
          "answer": "Srdce",
          "answerMeaning": "Srdce = Heart. Hruď is chest. Knowing both helps you describe symptoms more clearly."
        }
      ]
    },
