    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "The police are writing a report about a missing person. You describe their eyes as the color of the sky. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Zelené oči.",
            "Hnedé oči.",
            "Modré oči.",
            "Šedé oči."
          ],
          "answer": "Modré oči.",
          "answerMeaning": "Modré oči = Blue eyes. Oči = eyes. Color + body part makes a useful description."
        },
        {
          "situation": "You are describing a person with eyes the color of grass. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Červené oči.",
            "Zelené oči.",
            "Čierne oči.",
            "Blond oči."
          ],
          "answer": "Zelené oči.",
          "answerMeaning": "Zelené oči = Green eyes. The ending changes because oči is plural."
        },
        {
          "situation": "You are describing a suspect. Their hair is the color of coffee. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Červené vlasy.",
            "Blond vlasy.",
            "Čierne vlasy.",
            "Hnedé vlasy."
          ],
          "answer": "Hnedé vlasy.",
          "answerMeaning": "Hnedé vlasy = Brown hair. Vlasy = hair."
        },
        {
          "situation": "A witness says the person has very dark hair. What phrase matches that?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Čierne vlasy.",
            "Modré oči.",
            "Zelené oči.",
            "Biela taška."
          ],
          "answer": "Čierne vlasy.",
          "answerMeaning": "Čierne vlasy = Black hair. This is one of the most common police-description phrases."
        },
        {
          "situation": "You need to describe someone with light yellow hair. What phrase do you use?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Blond vlasy.",
            "Hnedé oči.",
            "Čierna taška.",
            "Zelené oči."
          ],
          "answer": "Blond vlasy.",
          "answerMeaning": "Blond vlasy = Blonde hair. In Slovak, blond often stays the same in this phrase."
        },
        {
          "situation": "You are describing someone with red hair. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Červené vlasy.",
            "Modré vlasy.",
            "Šedé oči.",
            "Hnedá taška."
          ],
          "answer": "Červené vlasy.",
          "answerMeaning": "Červené vlasy = Red hair. This was restored from the earlier trim because it belongs with personal descriptions."
        }
      ]
