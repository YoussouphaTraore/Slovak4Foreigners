    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "The traffic light turns červená. What does that tell you to do?",
          "instruction": "Choose the correct answer",
          "choices": [
            "Go",
            "Slow down",
            "Stop",
            "Turn right"
          ],
          "answer": "Stop",
          "answerMeaning": "Červená = Red = Stop. Slovak traffic lights follow the same sequence: červená stop, žltá slow down, zelená go."
        },
        {
          "situation": "You are looking for a pharmacy. Pharmacy signs use the color of grass. Which color are you looking for?",
          "instruction": "Choose the correct color",
          "choices": [
            "Červená",
            "Modrá",
            "Žltá",
            "Zelená"
          ],
          "answer": "Zelená",
          "answerMeaning": "Zelená = Green. Pharmacy signs in Slovakia are green with a cross."
        },
        {
          "situation": "It is a clear summer day. The sky is the same color as the sea. Which Slovak color word describes it?",
          "instruction": "Choose the correct color",
          "choices": [
            "Čierna",
            "Biela",
            "Modrá",
            "Žltá"
          ],
          "answer": "Modrá",
          "answerMeaning": "Modrá = Blue. It is also the color in Modrá karta, the EU Blue Card."
        },
        {
          "situation": "You lost your bag. The police ask for the color. It is the color of night. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Modrá taška.",
            "Biela taška.",
            "Žltá taška.",
            "Čierna taška."
          ],
          "answer": "Čierna taška.",
          "answerMeaning": "Čierna = Black. Taška = bag. Čierna taška = black bag."
        },
        {
          "situation": "You receive a letter from the Foreign Police. The envelope is the color of snow. Which color is it?",
          "instruction": "Choose the correct color",
          "choices": [
            "Biela",
            "Čierna",
            "Zelená",
            "Modrá"
          ],
          "answer": "Biela",
          "answerMeaning": "Biela = White. Many official envelopes and forms are white."
        },
        {
          "situation": "The traffic light turns žltá before red. What should you do?",
          "instruction": "Choose the correct answer",
          "choices": [
            "Speed up",
            "Slow down",
            "Park",
            "Turn left"
          ],
          "answer": "Slow down",
          "answerMeaning": "Žltá = Yellow. At a traffic light, yellow warns you to slow down because red is coming."
        }
      ]
    },
