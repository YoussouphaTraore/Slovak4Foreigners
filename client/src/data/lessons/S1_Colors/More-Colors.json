      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "A worker points to an oranžová vest. Which color is the vest?",
          "instruction": "Choose the correct color",
          "choices": [
            "Orange",
            "Pink",
            "Grey",
            "Brown"
          ],
          "answer": "Orange",
          "answerMeaning": "Oranžová = Orange. Safety vests and warning signs are often orange."
        },
        {
          "situation": "At the pharmacy you ask for the ružová box of medicine. What color is the box?",
          "instruction": "Choose the correct color",
          "choices": [
            "Grey",
            "Pink",
            "Brown",
            "Black"
          ],
          "answer": "Pink",
          "answerMeaning": "Ružová = Pink. It is useful when pointing to packages or labels."
        },
        {
          "situation": "The sky is šedá and it may rain. Which color is it?",
          "instruction": "Choose the correct color",
          "choices": [
            "Grey",
            "Green",
            "White",
            "Yellow"
          ],
          "answer": "Grey",
          "answerMeaning": "Šedá = Grey. You will hear it for sky, cars, coats, and buildings."
        },
        {
          "situation": "The police ask about a hnedá wallet. Which color is the wallet?",
          "instruction": "Choose the correct color",
          "choices": [
            "Red",
            "Blue",
            "Brown",
            "White"
          ],
          "answer": "Brown",
          "answerMeaning": "Hnedá = Brown. It is common for wallets, bags, coats, hair, and eyes."
        }
      ]
