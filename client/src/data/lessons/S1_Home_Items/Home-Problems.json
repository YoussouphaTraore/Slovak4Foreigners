    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "Your fridge stops cooling. What do you tell your landlord?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Práčka nefunguje.",
            "Chladnička nefunguje.",
            "Posteľ nefunguje.",
            "Skriňa nefunguje."
          ],
          "answer": "Chladnička nefunguje.",
          "answerMeaning": "Chladnička nefunguje = The fridge doesn't work. Nefunguje is the key phrase for reporting any broken appliance."
        },
        {
          "situation": "Your washing machine is leaking water. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Práčka sa pokazila.",
            "Posteľ sa pokazila.",
            "Kuchyňa sa pokazila.",
            "Stolička sa pokazila."
          ],
          "answer": "Práčka sa pokazila.",
          "answerMeaning": "Práčka sa pokazila = The washing machine broke. Sa pokazila is the feminine past form — práčka is a feminine noun."
        },
        {
          "situation": "You want the landlord to come see the problem in person. What do you ask?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Môžete prísť a pozrieť sa?",
            "Potrebujem opraviť posteľ.",
            "Kde je kúpeľňa?",
            "Stôl pre dvoch."
          ],
          "answer": "Môžete prísť a pozrieť sa?",
          "answerMeaning": "Môžete prísť a pozrieť sa? = Can you come and look? Useful when you can't describe the problem clearly over the phone."
        },
        {
          "situation": "Your wardrobe door fell off. What do you say you need to do?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Potrebujem opraviť skriňu.",
            "Potrebujem opraviť kuchyňu.",
            "Potrebujem opraviť spálňu.",
            "Potrebujem opraviť obývačku."
          ],
          "answer": "Potrebujem opraviť skriňu.",
          "answerMeaning": "Potrebujem opraviť skriňu = I need to fix the wardrobe. Skriňa = wardrobe/cabinet."
        }
      ]
