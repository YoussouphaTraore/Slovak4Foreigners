    {
      "id": "ex7",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You are at the doctor. You have a headache. Where do you point and what do you say?",
          "instruction": "Choose the correct word",
          "choices": ["Brucho", "Hlava", "Koleno", "Chrbát"],
          "answer": "Hlava",
          "answerMeaning": "Hlava = Head. Bolí ma hlava = My head hurts. The most common complaint at any doctor's office."
        },
        {
          "situation": "The doctor asks you to open your mouth so they can check your teeth. Which two body parts are they looking at?",
          "instruction": "Choose the correct pair",
          "choices": ["Nos a Ucho", "Ústa a Zuby", "Tvár a Vlasy", "Oko a Nos"],
          "answer": "Ústa a Zuby",
          "answerMeaning": "Ústa = Mouth. Zuby = Teeth. Otvorte ústa = Open your mouth. You will hear this at every dental appointment."
        },
        {
          "situation": "You fell and hurt your leg. You are at the emergency room. Which word do you use?",
          "instruction": "Choose the correct word",
          "choices": ["Ruka", "Koleno", "Noha", "Plece"],
          "answer": "Noha",
          "answerMeaning": "Noha = Leg / Foot. Bolí ma noha = My leg hurts. Note: Noha covers both leg and foot in Slovak — the same word for both."
        },
        {
          "situation": "The police need you to describe the person you saw. They had short dark hair. Which body part word do you use?",
          "instruction": "Choose the correct word",
          "choices": ["Tvár", "Hlava", "Vlasy", "Oko"],
          "answer": "Vlasy",
          "answerMeaning": "Vlasy = Hair. Krátke tmavé vlasy = Short dark hair. In the Colors lesson you will learn to describe hair color more precisely."
        },
        {
          "situation": "You have chest pain and call 155. Which word tells the dispatcher where the pain is?",
          "instruction": "Choose the correct word",
          "choices": ["Chrbát", "Brucho", "Hruď", "Plece"],
          "answer": "Hruď",
          "answerMeaning": "Hruď = Chest. Bolí ma hruď = My chest hurts. Chest pain is a 155 call — always say this clearly and immediately."
        },
        {
          "situation": "You hurt your back carrying boxes. What do you tell your doctor?",
          "instruction": "Choose the correct word",
          "choices": ["Brucho", "Srdce", "Hruď", "Chrbát"],
          "answer": "Chrbát",
          "answerMeaning": "Chrbát = Back. Bolí ma chrbát = My back hurts. One of the most common complaints at Slovak GP offices."
        },
        {
          "situation": "You twisted your knee playing sport. At the doctor you say 'Bolí ma...' and point. Which word completes the sentence?",
          "instruction": "Choose the correct word",
          "choices": ["Noha", "Prst", "Koleno", "Ruka"],
          "answer": "Koleno",
          "answerMeaning": "Koleno = Knee. Bolí ma koleno = My knee hurts. The phrase Bolí ma + body part is all you need to explain pain to any doctor."
        },
        {
          "situation": "You cut your finger while cooking. At the pharmacy you show them and say 'Bolí ma...' Which word do you use?",
          "instruction": "Choose the correct word",
          "choices": ["Ruka", "Noha", "Koleno", "Prst"],
          "answer": "Prst",
          "answerMeaning": "Prst = Finger. Bolí ma prst = My finger hurts. Prst also means toe — context makes it clear which one."
        }
      ]
    },
