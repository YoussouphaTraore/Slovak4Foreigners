    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "A delivery courier calls and asks for your address. What do you say first?",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Kde bývate?", "Moja adresa je...", "Koľko to stojí?", "Aký je dnes deň?"],
          "answer": "Moja adresa je...",
          "answerMeaning": "Moja adresa je... = My address is... — the natural way to start giving your address to anyone."
        },
        {
          "situation": "You are filling in an official form. It asks for your house number. Which word are you looking for?",
          "instruction": "Choose the correct word",
          "choices": ["Ulica", "Mesto", "Číslo domu", "Krajina"],
          "answer": "Číslo domu",
          "answerMeaning": "Číslo domu = House number. A required field on almost every Slovak official form."
        },
        {
          "situation": "Your friend asks where you live. You want to ask them the same question back. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["Aká je vaša adresa?", "Kde bývate?", "Moja adresa je...", "Číslo domu?"],
          "answer": "Kde bývate?",
          "answerMeaning": "Kde bývate? = Where do you live? Already familiar from the Verbs lesson (bývať = to live)."
        },
        {
          "situation": "You live on the fourth floor. The delivery driver asks which floor. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["Som na štvrtom poschodí.", "Som na prvom poschodí.", "Bývam v byte.", "Moja ulica je..."],
          "answer": "Som na štvrtom poschodí.",
          "answerMeaning": "Som na štvrtom poschodí = I am on the fourth floor. Štvrtý = fourth, the ordinal from the Numbers lesson."
        },
        {
          "situation": "You need to give your postal code to a bank. Which word are they asking for?",
          "instruction": "Choose the correct word",
          "choices": ["Ulica", "Mesto", "Poštové smerové číslo", "Byt"],
          "answer": "Poštové smerové číslo",
          "answerMeaning": "Poštové smerové číslo (often shortened to PSČ) = Postal code. Required on most official documents and deliveries."
        },
        {
          "situation": "A taxi app asks for your pickup address. What is the most useful phrase to type or say?",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Koľko to stojí?", "Moja adresa je...", "Kde je to?", "Aký je dnes deň?"],
          "answer": "Moja adresa je...",
          "answerMeaning": "Moja adresa je... = My address is... — works for taxis, deliveries, and any form asking where you are."
        },
        {
          "situation": "You call 155 for an emergency and need to give your exact location. What is the most critical phrase to say?",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Kde bývate?", "Moja adresa je... + ulica + číslo domu", "Aká je vaša adresa?", "Som na poschodí."],
          "answer": "Moja adresa je... + ulica + číslo domu",
          "answerMeaning": "Moja adresa je... + street name + house number is the critical information emergency services need to find you fast."
        },
        {
          "situation": "Someone asks where you live and you live in a flat, not a house. How do you mention this?",
          "instruction": "Choose the correct phrase",
          "choices": ["Bývam v byte.", "Bývam na ulici.", "Bývam v meste.", "Bývam v krajine."],
          "answer": "Bývam v byte.",
          "answerMeaning": "Bývam v byte = I live in a flat. Byt = flat/apartment — a useful clarification when describing your home."
        }
      ]
