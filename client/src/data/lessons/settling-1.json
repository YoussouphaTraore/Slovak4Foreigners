    {
      "id": "ex6",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "A government registration form has a field labelled 'PSČ' next to the city name. What do you fill in?",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Your full name", "Your 5-digit postal code", "Your phone number", "Your ID number"],
          "answer": "Your 5-digit postal code",
          "answerMeaning": "PSČ = Poštové smerovacie číslo = Postal code. Always 5 digits in Slovakia, e.g. 811 01 for central Bratislava."
        },
        {
          "situation": "You live in Slovakia's capital city. Which kraj do you write on the form?",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Nitriansky kraj", "Trnavský kraj", "Bratislavský kraj", "Košický kraj"],
          "answer": "Bratislavský kraj",
          "answerMeaning": "The capital Bratislava is in Bratislavský kraj — the smallest but most populated region in Slovakia."
        },
        {
          "situation": "Emergency services ask 'Aká je vaša adresa?' (from Lesson 4). What do they need from you?",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Your name", "Your nationality", "Your full address", "Your phone number"],
          "answer": "Your full address",
          "answerMeaning": "Aká je vaša adresa? = What is your address? — now you can give a complete answer: street, house number, city and PSČ!"
        },
        {
          "situation": "Your large apartment block has three staircases. The form asks for 'Vchod'. What does it mean?",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Flat number", "Floor", "Entrance / Staircase", "Building name"],
          "answer": "Entrance / Staircase",
          "answerMeaning": "Vchod = entrance / staircase. In Slovak paneláky (panel blocks) you often say 'vchod A' or 'vchod 1' to identify the right door."
        },
        {
          "situation": "You live on what English speakers call the '2nd floor.' What do Slovaks call it?",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Prízemie", "Druhé poschodie", "Prvé poschodie", "Nulté poschodie"],
          "answer": "Prvé poschodie",
          "answerMeaning": "1. poschodie = what English speakers call the 2nd floor. Slovak ground floor = Prízemie (floor 0), so every floor is counted one lower than in the UK/US!"
        },
        {
          "situation": "The form field says 'Obec'. You live in Košice, a large city. What do you write?",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Košický kraj", "Slovensko", "Košice", "040 01"],
          "answer": "Košice",
          "answerMeaning": "Obec literally means village, but on Slovak forms it refers to your municipality — cities count too. Write 'Košice', not the region."
        },
        {
          "situation": "Your flat number is 7 (sedem — from Lesson 5). How do you say your flat number in Slovak?",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Číslo bytu je päť.", "Číslo bytu je šesť.", "Číslo bytu je sedem.", "Číslo bytu je osem."],
          "answer": "Číslo bytu je sedem.",
          "answerMeaning": "Flat number seven. — sedem = 7 (from Lesson 5 — Numbers!). Now you can state any flat number in Slovak."
        },
        {
          "situation": "A delivery driver calls and asks for your address. You want to say 'My address is Hlavná 15, Bratislava.' How do you start?",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Aká je vaša adresa?", "Moja adresa je...", "Bývam v meste...", "Napíšte to, prosím."],
          "answer": "Moja adresa je...",
          "answerMeaning": "Moja adresa je... = My address is... — then give the street, house number, and city. Simple and clear!"
        }
      ]
    },
