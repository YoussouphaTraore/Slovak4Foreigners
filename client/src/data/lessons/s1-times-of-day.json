    {
      "id": "ex6",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You want to know what time it is right now. What do you ask?",
          "instruction": "Choose the correct phrase",
          "choices": ["O koľkej?", "Koľko je hodín?", "Aký je deň?", "Kedy?"],
          "answer": "Koľko je hodín?",
          "answerMeaning": "Koľko je hodín? = What time is it? The standard way to ask the current time."
        },
        {
          "situation": "You want to know what time your appointment is. What do you ask?",
          "instruction": "Choose the correct phrase",
          "choices": ["Koľko je hodín?", "O koľkej?", "Kde je to?", "Koľko to stojí?"],
          "answer": "O koľkej?",
          "answerMeaning": "O koľkej? = At what time? Used to ask when something will happen — different from asking the current time."
        },
        {
          "situation": "Your appointment with the doctor is at 10am. How do you say this in Slovak?",
          "instruction": "Choose the correct phrase",
          "choices": ["Je desiata.", "O desiatej.", "Desať hodín.", "Pol desiatej."],
          "answer": "O desiatej.",
          "answerMeaning": "O desiatej = At ten o'clock. The pattern O + time tells someone when something happens."
        },
        {
          "situation": "Someone asks 'Koľko je hodín?' and it is exactly 5 o'clock. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["O piatej.", "Je päť hodín.", "Päť minút.", "Pol piatej."],
          "answer": "Je päť hodín.",
          "answerMeaning": "Je päť hodín = It is five o'clock. Use Je... when telling the current time, not O... (which is for 'at' a time)."
        },
        {
          "situation": "You greet your colleague at 7am on the way into work. Which greeting fits this time of day?",
          "instruction": "Choose the most appropriate greeting",
          "choices": ["Dobrý večer", "Dobré ráno", "Dobrú noc", "Dobrý deň"],
          "answer": "Dobré ráno",
          "answerMeaning": "Dobré ráno = Good morning. Ráno = morning — from the Greetings lesson, now reinforced with clock time."
        },
        {
          "situation": "A shop's opening hours sign says it opens 'o ôsmej ráno.' What time does it open?",
          "instruction": "Choose the correct time",
          "choices": ["8pm", "8am", "10am", "Noon"],
          "answer": "8am",
          "answerMeaning": "O ôsmej ráno = At eight in the morning. Ráno after the time clarifies it's AM, not PM — Slovak doesn't always use a 24-hour clock in casual speech."
        },
        {
          "situation": "You want to say your meeting is at half past two. What is the key word you need?",
          "instruction": "Choose the correct word",
          "choices": ["Hodina", "Minúta", "Pol", "Noc"],
          "answer": "Pol",
          "answerMeaning": "Pol = Half. Pol tretej literally means 'half of three' — Slovak counts toward the next hour, unlike English 'half past two.'"
        },
        {
          "situation": "You are leaving a friend's house very late. Which phrase do you say as you leave?",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Dobré ráno!", "Dobrú noc!", "Dobrý deň!", "Dovidenia!"],
          "answer": "Dobrú noc!",
          "answerMeaning": "Dobrú noc! = Good night! Used when leaving late at night or going to sleep — different from Dobrý večer (good evening, used as a greeting earlier in the evening)."
        }
      ]
    },
