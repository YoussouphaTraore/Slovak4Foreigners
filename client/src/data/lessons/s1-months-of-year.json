    {
      "id": "ex6",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "Your residence permit expires in March. How do you tell the Foreign Police officer when it expires?",
          "instruction": "Choose the correct phrase",
          "choices": ["Platí do januára.", "Platí do marca.", "Platí do júna.", "Platí do decembra."],
          "answer": "Platí do marca.",
          "answerMeaning": "Platí do marca = It is valid until March. Marec = March, an essential word when discussing permit and document deadlines."
        },
        {
          "situation": "Your friend asks when your birthday is. It is in July. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["Moje narodeniny sú v júli.", "Moje narodeniny sú v marci.", "Moje narodeniny sú v septembri.", "Moje narodeniny sú v januári."],
          "answer": "Moje narodeniny sú v júli.",
          "answerMeaning": "Moje narodeniny sú v júli = My birthday is in July. Júl = July."
        },
        {
          "situation": "Your work contract started in September. How do you say how long you've been working there since then?",
          "instruction": "Choose the correct phrase",
          "choices": ["Pracujem tu od septembra.", "Pracujem tu od marca.", "Pracujem tu zajtra.", "Pracujem tu každý mesiac."],
          "answer": "Pracujem tu od septembra.",
          "answerMeaning": "Pracujem tu od septembra = I have been working here since September. Od + month = since that month."
        },
        {
          "situation": "Your landlord says the rent increases starting next month. What does he mean?",
          "instruction": "Choose the correct phrase",
          "choices": ["Tento mesiac", "Minulý mesiac", "Budúci mesiac", "Každý mesiac"],
          "answer": "Budúci mesiac",
          "answerMeaning": "Budúci mesiac = Next month. The rent increase starts from the following month, not this one."
        },
        {
          "situation": "You arrived in Slovakia in January and it is now June. How long have you been here, roughly?",
          "instruction": "Choose the correct phrase",
          "choices": ["Som tu od januára.", "Som tu od júna.", "Som tu od decembra.", "Som tu od marca."],
          "answer": "Som tu od januára.",
          "answerMeaning": "Som tu od januára = I have been here since January. Od + the month you arrived."
        },
        {
          "situation": "An official letter says your appointment is in October. Which month do you look for in your calendar?",
          "instruction": "Choose the correct month",
          "choices": ["August", "September", "Október", "November"],
          "answer": "Október",
          "answerMeaning": "Október = October. Note it looks similar to English but has its own Slovak pronunciation."
        },
        {
          "situation": "Your gym membership was paid last month. How do you describe this to the receptionist?",
          "instruction": "Choose the correct phrase",
          "choices": ["Zaplatil som tento mesiac.", "Zaplatil som minulý mesiac.", "Zaplatím budúci mesiac.", "Platím každý týždeň."],
          "answer": "Zaplatil som minulý mesiac.",
          "answerMeaning": "Zaplatil som minulý mesiac = I paid last month. Minulý mesiac = last month, from the Weeks of the Month lesson."
        },
        {
          "situation": "You need to renew your health insurance every December. How do you describe this recurring deadline?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Obnovujem to v decembri.",
            "Obnovujem to v januári.",
            "Obnovujem to v máji.",
            "Obnovujem to v auguste."
          ],
          "answer": "Obnovujem to v decembri.",
          "answerMeaning": "Obnovujem to v decembri = I renew it in December. December = December — a key month to remember for any yearly renewal."
        }
      ]
    },
