    {
      "id": "ex7",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You are at a restaurant. You don't eat meat. What do you tell the waiter?",
          "instruction": "Choose the correct phrase",
          "choices": ["Nejem mäso.", "Mám mäso.", "Chcem mäso.", "Som mäso."],
          "answer": "Nejem mäso.",
          "answerMeaning": "Nejem mäso = I don't eat meat. Nejem from the Verbs lesson (Jem = I eat) + Ne- negative prefix."
        },
        {
          "situation": "You are vegetarian and a man. How do you tell the waiter?",
          "instruction": "Choose the correct phrase",
          "choices": ["Som vegetariánka.", "Som vegetarián.", "Nejem zeleninu.", "Mám alergiu."],
          "answer": "Som vegetarián.",
          "answerMeaning": "Som vegetarián = I am vegetarian (male form). Vegetariánka is the female form."
        },
        {
          "situation": "You are allergic to fish. What do you tell the waiter before ordering?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Som alergický na ryby.",
            "Nemám rybu.",
            "Chcem rybu.",
            "Mám rybu."
          ],
          "answer": "Som alergický na ryby.",
          "answerMeaning": "Som alergický na ryby = I am allergic to fish (male form). Always say this clearly before ordering — it's important for your safety."
        },
        {
          "situation": "You taste the soup and it's delicious. What do you say to the waiter?",
          "instruction": "Choose the correct phrase",
          "choices": ["Je to slané.", "Je to chutné!", "Je to pikantné.", "Je to sladké."],
          "answer": "Je to chutné!",
          "answerMeaning": "Je to chutné! = It's tasty! The most common compliment you can give about food in Slovak."
        },
        {
          "situation": "The dish is too hot/spicy for you. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["Je to sladké.", "Je to chutné.", "Je to pikantné!", "Je to slané."],
          "answer": "Je to pikantné!",
          "answerMeaning": "Je to pikantné! = It's spicy! Useful to know before you order something you might not be ready for."
        },
        {
          "situation": "It's 8am and you are hungry. Which meal are you about to have?",
          "instruction": "Choose the correct word",
          "choices": ["Obed", "Večera", "Raňajky", "Mäso"],
          "answer": "Raňajky",
          "answerMeaning": "Raňajky = Breakfast. The first meal of the day in Slovak."
        },
        {
          "situation": "It's 1pm and your colleagues are heading to eat. Which meal is this?",
          "instruction": "Choose the correct word",
          "choices": ["Raňajky", "Obed", "Večera", "Syr"],
          "answer": "Obed",
          "answerMeaning": "Obed = Lunch. The midday meal — very important in Slovak daily routine."
        },
        {
          "situation": "Your landlord invites you for the evening meal. What does he call it?",
          "instruction": "Choose the correct word",
          "choices": ["Raňajky", "Obed", "Večera", "Ovocie"],
          "answer": "Večera",
          "answerMeaning": "Večera = Dinner. The evening meal."
        }
      ]
    },
