    {
      "id": "ex4",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "Your partner's mother is visiting. Which Slovak word means mother-in-law?",
          "instruction": "Choose the correct word",
          "choices": [
            "Svokor",
            "Svokra",
            "Manželka",
            "Dcéra"
          ],
          "answer": "Svokra",
          "answerMeaning": "Svokra = mother-in-law. Svokor = father-in-law."
        },
        {
          "situation": "Your partner's father is calling. Which word means father-in-law?",
          "instruction": "Choose the correct word",
          "choices": [
            "Svokor",
            "Svokra",
            "Strýko",
            "Dedko"
          ],
          "answer": "Svokor",
          "answerMeaning": "Svokor = father-in-law."
        },
        {
          "situation": "Kai is not married and has no partner. What can Kai say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Som ženatý.",
            "Som vydatá.",
            "Som slobodný.",
            "Mám manželku."
          ],
          "answer": "Som slobodný.",
          "answerMeaning": "Slobodný = single (male form). Slobodná = single (female form). Both can fit Kai."
        },
        {
          "situation": "Someone asks if you are married. You are a man. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Som slobodný.",
            "Som ženatý.",
            "Som vydatá.",
            "Som syn."
          ],
          "answer": "Som ženatý.",
          "answerMeaning": "Som ženatý = I am married, said by a man. A married woman says Som vydatá."
        },
        {
          "situation": "A woman says she is married. Which phrase is correct?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Som vydatá.",
            "Som ženatý.",
            "Som svokra.",
            "Som svokor."
          ],
          "answer": "Som vydatá.",
          "answerMeaning": "Som vydatá = I am married, said by a woman."
        },
        {
          "situation": "A form asks for your in-laws. Which Slovak word means in-laws?",
          "instruction": "Choose the correct word",
          "choices": [
            "Svokrovci",
            "Súrodenci",
            "Rodičia",
            "Deti"
          ],
          "answer": "Svokrovci",
          "answerMeaning": "Svokrovci = in-laws."
        }
      ]
    },
