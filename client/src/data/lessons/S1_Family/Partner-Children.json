    {
      "id": "ex4",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "Your neighbour asks about your wife's parents. Which Slovak word means 'wife'?",
          "instruction": "Choose the correct word",
          "choices": [
            "Manžel",
            "Manželka",
            "Sestra",
            "Dcéra"
          ],
          "answer": "Manželka",
          "answerMeaning": "Manželka = wife. Manžel = husband."
        },
        {
          "situation": "Someone asks if you have children. You have one son. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Mám syna.",
            "Mám dcéru.",
            "Mám brata.",
            "Mám otca."
          ],
          "answer": "Mám syna.",
          "answerMeaning": "Syn = son. Mám syna = I have a son."
        },
        {
          "situation": "You introduce your daughter to a colleague. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "To je môj syn.",
            "To je moja dcéra.",
            "To je moja mama.",
            "To je moja sestra."
          ],
          "answer": "To je moja dcéra.",
          "answerMeaning": "Dcéra = daughter. To je moja dcéra = This is my daughter."
        },
        {
          "situation": "Someone asks if you have children. You have two children. Which word do you need?",
          "instruction": "Choose the correct word",
          "choices": [
            "Deti",
            "Rodičia",
            "Súrodenci",
            "Svokrovci"
          ],
          "answer": "Deti",
          "answerMeaning": "Deti = children."
        },
        {
          "situation": "You want to say 'This is my husband.' Which phrase is correct?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "To je môj manžel.",
            "To je moja manželka.",
            "To je môj syn.",
            "To je moja dcéra."
          ],
          "answer": "To je môj manžel.",
          "answerMeaning": "Môj manžel = my husband."
        },
        {
          "situation": "You are filling in a form and it asks for your spouse. What does spouse mean here?",
          "instruction": "Choose the correct meaning",
          "choices": [
            "Husband or wife",
            "Brother or sister",
            "Mother or father",
            "Son or daughter"
          ],
          "answer": "Husband or wife",
          "answerMeaning": "Spouse here means your partner: manžel, manželka, partner, or partnerka depending on context."
        }
      ]
    },
    {
