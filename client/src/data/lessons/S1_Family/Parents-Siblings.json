    {
      "id": "ex4",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "Your colleague asks if you have brothers or sisters. You have one brother. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Mám sestru.",
            "Mám brata.",
            "Mám syna.",
            "Mám otca."
          ],
          "answer": "Mám brata.",
          "answerMeaning": "Brat = brother. Mám brata = I have a brother."
        },
        {
          "situation": "Someone asks where your parents live. What word means parents?",
          "instruction": "Choose the correct word",
          "choices": [
            "Rodičia",
            "Súrodenci",
            "Deti",
            "Svokrovci"
          ],
          "answer": "Rodičia",
          "answerMeaning": "Rodičia = parents."
        },
        {
          "situation": "You are an only child. What do you say about siblings?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Mám súrodencov.",
            "Nemám súrodencov.",
            "Mám rodičov.",
            "Nemám rodičov."
          ],
          "answer": "Nemám súrodencov.",
          "answerMeaning": "Súrodenci = siblings. Nemám súrodencov = I don't have siblings."
        },
        {
          "situation": "You introduce your sister to a friend. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "To je môj brat.",
            "To je moja sestra.",
            "To je moja mama.",
            "To je môj otec."
          ],
          "answer": "To je moja sestra.",
          "answerMeaning": "Sestra = sister."
        },
        {
          "situation": "You want to say your mother lives in Košice. Which word do you need?",
          "instruction": "Choose the correct word",
          "choices": [
            "Mama",
            "Otec",
            "Brat",
            "Sestra"
          ],
          "answer": "Mama",
          "answerMeaning": "Mama = mother / mum."
        },
        {
          "situation": "You want to say your father is from Prešov. Which word do you need?",
          "instruction": "Choose the correct word",
          "choices": [
            "Otec",
            "Mama",
            "Dcéra",
            "Teta"
          ],
          "answer": "Otec",
          "answerMeaning": "Otec = father / dad."
        }
      ]
    },
