    {
      "id": "ex4",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "Your grandparents are visiting from abroad. Which Slovak phrase means grandparents?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Starí rodičia",
            "Moji rodičia",
            "Moje deti",
            "Moji súrodenci"
          ],
          "answer": "Starí rodičia",
          "answerMeaning": "Starí rodičia = grandparents."
        },
        {
          "situation": "How do you introduce your grandma to a Slovak friend?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "To je môj dedko.",
            "To je moja babička.",
            "To je moja teta.",
            "To je moja sestra."
          ],
          "answer": "To je moja babička.",
          "answerMeaning": "Babička = grandma."
        },
        {
          "situation": "You have an uncle and an aunt who live nearby. Which two words do you use?",
          "instruction": "Choose the correct pair",
          "choices": [
            "Strýko a teta",
            "Bratranec a sesternica",
            "Dedko a babička",
            "Brat a sestra"
          ],
          "answer": "Strýko a teta",
          "answerMeaning": "Strýko = uncle. Teta = aunt."
        },
        {
          "situation": "Your cousin (female) is visiting. How do you introduce her?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "To je môj bratranec.",
            "To je moja sesternica.",
            "To je moja sestra.",
            "To je moja teta."
          ],
          "answer": "To je moja sesternica.",
          "answerMeaning": "Sesternica = female cousin. Bratranec = male cousin."
        },
        {
          "situation": "Your mother's brother is visiting. Which word do you use?",
          "instruction": "Choose the correct word",
          "choices": [
            "Strýko",
            "Teta",
            "Dedko",
            "Brat"
          ],
          "answer": "Strýko",
          "answerMeaning": "Strýko = uncle."
        },
        {
          "situation": "Your father's sister is visiting. Which word do you use?",
          "instruction": "Choose the correct word",
          "choices": [
            "Teta",
            "Babička",
            "Sestra",
            "Dcéra"
          ],
          "answer": "Teta",
          "answerMeaning": "Teta = aunt."
        }
      ]
    },
