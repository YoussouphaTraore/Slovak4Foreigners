      "scenarios": [
        {
          "situation": "You are talking about your boy at school. Which phrase means my son?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "môj syn",
            "moja dcéra",
            "moje dieťa",
            "je v škole"
          ],
          "answer": "môj syn",
          "answerMeaning": "môj syn = my son. Use it when speaking about your boy."
        },
        {
          "situation": "You are talking about your girl at school. Which phrase means my daughter?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "moja dcéra",
            "môj syn",
            "moje dieťa",
            "chodí do školy"
          ],
          "answer": "moja dcéra",
          "answerMeaning": "moja dcéra = my daughter. Use it when speaking about your girl."
        },
        {
          "situation": "You want a neutral phrase for your child. Which phrase do you need?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "moje dieťa",
            "môj syn",
            "moja dcéra",
            "chodí do prvej triedy"
          ],
          "answer": "moje dieťa",
          "answerMeaning": "moje dieťa = my child. It works when you do not need to say son or daughter."
        },
        {
          "situation": "A teacher asks if your child attends school. Which phrase means goes to school?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "chodí do školy",
            "je v škole",
            "môj syn",
            "moja dcéra"
          ],
          "answer": "chodí do školy",
          "answerMeaning": "chodí do školy = goes to school. Chodí is used for he/she goes or attends."
        },
        {
          "situation": "Someone asks where your child is right now. Which phrase means is at school?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "je v škole",
            "chodí do školy",
            "moje dieťa",
            "môj syn"
          ],
          "answer": "je v škole",
          "answerMeaning": "je v škole = is at school. Use it for where the child is now."
        },
        {
          "situation": "You need to say your child goes to first grade. Which phrase fits?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "chodí do prvej triedy",
            "chodí do školy",
            "je v škole",
            "moja dcéra"
          ],
          "answer": "chodí do prvej triedy",
          "answerMeaning": "chodí do prvej triedy = goes to first grade. Trieda can mean class or grade in school context."
        }
      ]
