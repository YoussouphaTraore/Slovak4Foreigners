    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "The school day begins at eight. Which word means starts?",
          "instruction": "Choose the correct word",
          "choices": [
            "začína",
            "končí",
            "ráno",
            "zajtra"
          ],
          "answer": "začína",
          "answerMeaning": "začína = starts. Example: Škola začína ráno. = School starts in the morning."
        },
        {
          "situation": "The school day is over. Which word means finishes?",
          "instruction": "Choose the correct word",
          "choices": [
            "končí",
            "začína",
            "poobede",
            "dnes"
          ],
          "answer": "končí",
          "answerMeaning": "končí = finishes. Example: Škola končí poobede. = School finishes in the afternoon."
        },
        {
          "situation": "Your child goes to school before lunch. Which word means in the morning?",
          "instruction": "Choose the correct word",
          "choices": [
            "ráno",
            "poobede",
            "dnes",
            "zajtra"
          ],
          "answer": "ráno",
          "answerMeaning": "ráno = in the morning. It is useful for school start times."
        },
        {
          "situation": "Your child comes home after lunch. Which word means in the afternoon?",
          "instruction": "Choose the correct word",
          "choices": [
            "poobede",
            "ráno",
            "končí",
            "začína"
          ],
          "answer": "poobede",
          "answerMeaning": "poobede = in the afternoon. It is useful for school finish times."
        },
        {
          "situation": "You mean this day, not another day. Which word means today?",
          "instruction": "Choose the correct word",
          "choices": [
            "dnes",
            "zajtra",
            "ráno",
            "poobede"
          ],
          "answer": "dnes",
          "answerMeaning": "dnes = today. Use it for something happening on this day."
        },
        {
          "situation": "You mean the next day. Which word means tomorrow?",
          "instruction": "Choose the correct word",
          "choices": [
            "zajtra",
            "dnes",
            "začína",
            "končí"
          ],
          "answer": "zajtra",
          "answerMeaning": "zajtra = tomorrow. Use it for something happening the next day."
        }
      ]
    },
