    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "A very small child goes to daycare before kindergarten. Which Slovak word fits?",
          "instruction": "Choose the correct school type",
          "choices": [
            "jasle",
            "materská škola",
            "základná škola",
            "univerzita"
          ],
          "answer": "jasle",
          "answerMeaning": "jasle = nursery / daycare. It is for very young children before kindergarten."
        },
        {
          "situation": "A young child goes to kindergarten. Which Slovak phrase fits?",
          "instruction": "Choose the correct school type",
          "choices": [
            "materská škola",
            "jasle",
            "stredná škola",
            "vysoká škola"
          ],
          "answer": "materská škola",
          "answerMeaning": "materská škola = kindergarten. People often shorten it to škôlka in everyday speech."
        },
        {
          "situation": "A child starts normal school around age six. Which phrase means primary school?",
          "instruction": "Choose the correct school type",
          "choices": [
            "základná škola",
            "materská škola",
            "univerzita",
            "jasle"
          ],
          "answer": "základná škola",
          "answerMeaning": "základná škola = primary / elementary school. It is often abbreviated as ZŠ."
        },
        {
          "situation": "A teenager studies after primary school. Which phrase means secondary school?",
          "instruction": "Choose the correct school type",
          "choices": [
            "stredná škola",
            "základná škola",
            "materská škola",
            "jasle"
          ],
          "answer": "stredná škola",
          "answerMeaning": "stredná škola = secondary school / high school. It is often abbreviated as SŠ."
        },
        {
          "situation": "Someone talks about higher education after secondary school. Which phrase can mean college or higher education?",
          "instruction": "Choose the correct school type",
          "choices": [
            "vysoká škola",
            "stredná škola",
            "základná škola",
            "jasle"
          ],
          "answer": "vysoká škola",
          "answerMeaning": "vysoká škola = college / higher education institution. It is a broad term for study after secondary school."
        },
        {
          "situation": "You need the word for university. Which word fits?",
          "instruction": "Choose the correct school type",
          "choices": [
            "univerzita",
            "vysoká škola",
            "stredná škola",
            "materská škola"
          ],
          "answer": "univerzita",
          "answerMeaning": "univerzita = university. A university is one type of vysoká škola."
        }
      ]
    },
