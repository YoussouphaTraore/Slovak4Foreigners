    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "The school asks who you are in relation to the child. Which word means parent?",
          "instruction": "Choose the correct word",
          "choices": [
            "rodič",
            "správa",
            "stretnutie",
            "ospravedlnenie"
          ],
          "answer": "rodič",
          "answerMeaning": "rodič = parent. Use it when the school asks who you are."
        },
        {
          "situation": "The teacher wants to meet you. Which word means meeting?",
          "instruction": "Choose the correct word",
          "choices": [
            "stretnutie",
            "správa",
            "rodič",
            "prosím, zavolajte mi"
          ],
          "answer": "stretnutie",
          "answerMeaning": "stretnutie = meeting. You may hear it for a parent-teacher meeting."
        },
        {
          "situation": "You receive text from school. Which word means message?",
          "instruction": "Choose the correct word",
          "choices": [
            "správa",
            "stretnutie",
            "ospravedlnenie",
            "rodič"
          ],
          "answer": "správa",
          "answerMeaning": "správa = message. Use it for a text, app message, or written notice."
        },
        {
          "situation": "Your child was away and the school needs a note. Which word means excuse note?",
          "instruction": "Choose the correct word",
          "choices": [
            "ospravedlnenie",
            "správa",
            "stretnutie",
            "rodič"
          ],
          "answer": "ospravedlnenie",
          "answerMeaning": "ospravedlnenie = excuse note / explanation for absence. Schools may ask for this after a child misses class."
        },
        {
          "situation": "You need to tell the school your child is absent today. Which phrase fits?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "moje dieťa chýba",
            "prosím, zavolajte mi",
            "stretnutie",
            "správa"
          ],
          "answer": "moje dieťa chýba",
          "answerMeaning": "moje dieťa chýba = my child is absent. Chýba can mean is missing or is absent from class."
        },
        {
          "situation": "You want the school to phone you back. Which phrase do you use?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "prosím, zavolajte mi",
            "moje dieťa chýba",
            "ospravedlnenie",
            "rodič"
          ],
          "answer": "prosím, zavolajte mi",
          "answerMeaning": "prosím, zavolajte mi = please call me. This is polite and formal."
        }
      ]
    },
