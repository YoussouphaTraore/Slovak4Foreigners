    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "Your child does not understand the lesson. Which phrase fits?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "nerozumie",
            "je choré",
            "potrebuje pomoc",
            "neviem"
          ],
          "answer": "nerozumie",
          "answerMeaning": "nerozumie = does not understand. Use it when the child does not understand something at school."
        },
        {
          "situation": "Your child feels unwell and cannot learn today. Which phrase means is sick?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "je choré",
            "nerozumie",
            "nemá pomôcky",
            "potrebuje pomoc"
          ],
          "answer": "je choré",
          "answerMeaning": "je choré = is sick. This form works naturally with dieťa, meaning child."
        },
        {
          "situation": "Your child needs support from the teacher. Which phrase do you need?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "potrebuje pomoc",
            "neviem",
            "je choré",
            "nemá domácu úlohu"
          ],
          "answer": "potrebuje pomoc",
          "answerMeaning": "potrebuje pomoc = needs help. It is useful when asking the school to support the child."
        },
        {
          "situation": "Your child came without homework. Which phrase fits?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "nemá domácu úlohu",
            "nemá pomôcky",
            "nerozumie",
            "je choré"
          ],
          "answer": "nemá domácu úlohu",
          "answerMeaning": "nemá domácu úlohu = does not have homework. Domáca úloha means homework."
        },
        {
          "situation": "Your child forgot books, pens, or other school things. Which phrase fits?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "nemá pomôcky",
            "nemá domácu úlohu",
            "potrebuje pomoc",
            "neviem"
          ],
          "answer": "nemá pomôcky",
          "answerMeaning": "nemá pomôcky = does not have school materials. Pomôcky are tools or materials used in school."
        },
        {
          "situation": "The teacher asks a question and you do not know the answer. What can you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "neviem",
            "nerozumie",
            "je choré",
            "potrebuje pomoc"
          ],
          "answer": "neviem",
          "answerMeaning": "neviem = I do not know. It is simple and useful when you cannot answer."
        }
      ]
