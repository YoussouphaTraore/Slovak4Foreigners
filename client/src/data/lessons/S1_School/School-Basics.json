    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You are standing outside the school building. Which Slovak word means school?",
          "instruction": "Choose the correct word",
          "choices": [
            "škola",
            "trieda",
            "učiteľ",
            "žiak"
          ],
          "answer": "škola",
          "answerMeaning": "škola = school. Use this for the school building or school as a place."
        },
        {
          "situation": "You need to find your class or classroom. Which word do you need?",
          "instruction": "Choose the correct word",
          "choices": [
            "trieda",
            "škola",
            "učiteľka",
            "žiačka"
          ],
          "answer": "trieda",
          "answerMeaning": "trieda = class / classroom. It can mean the group of students or the classroom."
        },
        {
          "situation": "A man teaches the class. Which Slovak word fits?",
          "instruction": "Choose the correct word",
          "choices": [
            "učiteľ",
            "učiteľka",
            "žiak",
            "trieda"
          ],
          "answer": "učiteľ",
          "answerMeaning": "učiteľ = male teacher. Use it for a man who teaches."
        },
        {
          "situation": "A woman teaches the class. Which Slovak word fits?",
          "instruction": "Choose the correct word",
          "choices": [
            "učiteľka",
            "učiteľ",
            "žiačka",
            "škola"
          ],
          "answer": "učiteľka",
          "answerMeaning": "učiteľka = female teacher. The ending -ka often marks a female person."
        },
        {
          "situation": "A boy is learning in school. Which Slovak word fits?",
          "instruction": "Choose the correct word",
          "choices": [
            "žiak",
            "žiačka",
            "učiteľ",
            "trieda"
          ],
          "answer": "žiak",
          "answerMeaning": "žiak = male pupil / student. Use it for a boy or male student at school."
        },
        {
          "situation": "A girl is learning in school. Which Slovak word fits?",
          "instruction": "Choose the correct word",
          "choices": [
            "žiačka",
            "žiak",
            "učiteľka",
            "škola"
          ],
          "answer": "žiačka",
          "answerMeaning": "žiačka = female pupil / student. Use it for a girl or female student at school."
        }
      ]
    },
