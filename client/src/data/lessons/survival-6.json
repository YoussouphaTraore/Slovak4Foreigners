    {
      "id": "ex6",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "At the hospital (Nemocnica), the receptionist says the doctor's office is 'vpravo, druhé dvere.' Which way do you go?",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Hore",
            "Vľavo",
            "Vpravo",
            "Dole"
          ],
          "answer": "Vpravo",
          "answerMeaning": "Vpravo = Right — useful when navigating the Nemocnica from Lesson 4! (druhé dvere = second door)"
        },
        {
          "situation": "You need a pharmacy. A passer-by says 'Je to blízko, päť minút pešo.' Do you need a taxi?",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Áno, je to ďaleko.",
            "Nie, je to blízko.",
            "Neviem.",
            "Pomoc!"
          ],
          "answer": "Nie, je to blízko.",
          "answerMeaning": "No, it's nearby. — päť minút pešo = five minutes on foot. Blízko = near, ďaleko = far."
        },
        {
          "situation": "A tourist asks where the Policajná stanica is. It's straight ahead. What do you tell them?",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Choďte vľavo.",
            "Choďte vpravo.",
            "Choďte priamo.",
            "Je to ďaleko."
          ],
          "answer": "Choďte priamo.",
          "answerMeaning": "Go straight ahead. — Policajná stanica = Police station (from Lesson 4). Priamo = straight."
        },
        {
          "situation": "You call 155 and need to tell the dispatcher you're standing outside the building. Which word do you use?",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Vnútri",
            "Vonku",
            "Hore",
            "Vedľa"
          ],
          "answer": "Vonku",
          "answerMeaning": "Vonku = Outside — critical when calling emergency services and giving your position (Lesson 4)!"
        },
        {
          "situation": "Your friend texts: 'Čakám pred nemocnicou.' Where are they waiting?",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Inside the hospital",
            "Behind the hospital",
            "In front of the hospital",
            "Above the hospital"
          ],
          "answer": "In front of the hospital",
          "answerMeaning": "Pred = in front of — Nemocnica = hospital (Lesson 4). Pred nemocnicou = in front of the hospital."
        },
        {
          "situation": "You want to meet someone at the café directly across from the bank. How do you say 'opposite the bank'?",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Vedľa banky",
            "Naproti banke",
            "Pred bankou",
            "Za bankou"
          ],
          "answer": "Naproti banke",
          "answerMeaning": "Naproti = opposite / across from — one of the most useful meeting-point words in Slovak."
        },
        {
          "situation": "At the supermarket checkout (Lesson 5), you remember your card is in the car outside. What do you say?",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Platím kartou.",
            "Karta je vonku.",
            "Je to blízko.",
            "Zadarmo!"
          ],
          "answer": "Karta je vonku.",
          "answerMeaning": "The card is outside. — vonku = outside (this lesson) + karta = card (Lesson 5). Two lessons in one sentence!"
        },
        {
          "situation": "The police need your exact location. You're standing between the pharmacy and the post office. What do you say?",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Som pred lekárňou.",
            "Som za poštou.",
            "Som medzi lekárňou a poštou.",
            "Som vedľa banky."
          ],
          "answer": "Som medzi lekárňou a poštou.",
          "answerMeaning": "I am between the pharmacy and the post office. — medzi = between. Perfect for Lesson 4's call script (Volám sa... Som na...)!"
        },
        {
          "situation": "The lift is broken. The doctor's office is on the third floor. Which direction must you go?",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Dole",
            "Vonku",
            "Vpravo",
            "Hore"
          ],
          "answer": "Hore",
          "answerMeaning": "Hore = Up / Upstairs — when the lift (výťah) is out of order, you will hear this a lot!"
        },
        {
          "situation": "You are on the second floor of the hospital. The pharmacy (lekáreň) is on the ground floor. The nurse points and says you need to go...",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Hore",
            "Vonku",
            "Vpravo",
            "Dole"
          ],
          "answer": "Dole",
          "answerMeaning": "Dole = Down / Downstairs — prízemie (ground floor) is always dole from any upper floor."
        },
        {
          "situation": "The shopping centre map shows 'Lekáreň: nad reštauráciou.' Where is the pharmacy?",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Below the restaurant",
            "Next to the restaurant",
            "Above the restaurant",
            "Behind the restaurant"
          ],
          "answer": "Above the restaurant",
          "answerMeaning": "Nad = above / over. Reštaurácia = restaurant. Nad reštauráciou = above the restaurant."
        },
        {
          "situation": "Your colleague says the storage room is 'pod schodmi, vľavo.' Where should you look?",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Above the stairs",
            "To the right of the stairs",
            "Below / under the stairs",
            "Opposite the stairs"
          ],
          "answer": "Below / under the stairs",
          "answerMeaning": "Pod = below / under. Schody = stairs. Pod schodmi = under the stairs — very common in Slovak buildings!"
        },
        {
          "situation": "You walked past the café entrance and are now on the other side. Your friend calls asking where you are. What do you say?",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Som pred kaviarňou.",
            "Som za kaviarňou.",
            "Som vedľa kaviarne.",
            "Som naproti kaviarni."
          ],
          "answer": "Som za kaviarňou.",
          "answerMeaning": "Za = behind / past. Som za kaviarňou = I'm behind/past the café. Easy to overshoot your stop!"
        },
        {
          "situation": "The ambulance dispatcher asks exactly where you are. You are at that very spot. What do you say to confirm you are right there?",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Som tam.",
            "Som tu.",
            "Som blízko.",
            "Som vonku."
          ],
          "answer": "Som tu.",
          "answerMeaning": "Tu = here. Som tu = I am here — use tu for your own position. Tam = over there (for pointing to something away from you)."
        },
        {
          "situation": "You are giving someone directions over the phone. You can see the building they are looking for from where you stand. What do you say?",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Je to tu.",
            "Je to tam.",
            "Je to blízko.",
            "Je to ďaleko."
          ],
          "answer": "Je to tam.",
          "answerMeaning": "Tam = there / over there. Je to tam = it's over there. Use tam when pointing to something away from you."
        },
        {
          "situation": "You call 155 (Lesson 4) and need to give a precise landmark. You can see the pharmacy right next to you. What do you tell the dispatcher?",
          "instruction": "Choose the most appropriate phrase",
          "choices": [
            "Som vnútri lekárne.",
            "Som pred lekárňou.",
            "Som pri lekárni.",
            "Som za lekárňou."
          ],
          "answer": "Som pri lekárni.",
          "answerMeaning": "Pri = at / right next to. Som pri lekárni = I am right at the pharmacy — more precise than pred (in front of) when pinpointing your location for emergency services!"
        }
      ]
    },
