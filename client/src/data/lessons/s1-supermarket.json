      "id": "ex6",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You only need a few items, not a full trolley load. What do you grab at the entrance?",
          "instruction": "Choose the correct word",
          "choices": ["Vozík", "Košík", "Regál", "Pokladňa"],
          "answer": "Košík",
          "answerMeaning": "Košík = Basket. Perfect for a quick shop with just a few items."
        },
        {
          "situation": "You're doing a big weekly shop with lots of items. What should you use instead?",
          "instruction": "Choose the correct word",
          "choices": ["Košík", "Vozík", "Regál", "Účtenka"],
          "answer": "Vozík",
          "answerMeaning": "Vozík = Trolley/Cart. Better for a larger shop than a basket."
        },
        {
          "situation": "You can't find the bread section. What do you ask a staff member?",
          "instruction": "Choose the correct phrase",
          "choices": ["Kde nájdem chlieb?", "Máte vernostnú kartu?", "Pol kila, prosím.", "Taška, prosím."],
          "answer": "Kde nájdem chlieb?",
          "answerMeaning": "Kde nájdem chlieb? = Where can I find bread? Kde nájdem...? works for locating any item in the shop."
        },
        {
          "situation": "At the deli counter, you want half a kilo of cheese. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["Veľa syra, prosím.", "Trochu syra, prosím.", "Pol kila syra, prosím.", "Kde je syr?"],
          "answer": "Pol kila syra, prosím.",
          "answerMeaning": "Pol kila syra, prosím = Half a kilo of cheese, please. Pol kila is a common way to order at deli counters."
        },
        {
          "situation": "The cashier scans your items and asks how you're paying. You want to pay by card. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["Hotovosťou.", "Kartou.", "Veľa.", "Trochu."],
          "answer": "Kartou.",
          "answerMeaning": "Kartou = By card. Simple one-word answer to the very common question Kartou alebo hotovosťou?"
        },
        {
          "situation": "The cashier asks 'Máte vernostnú kartu?' What are they asking?",
          "instruction": "Choose the correct meaning",
          "choices": [
            "Do you have a receipt?",
            "Do you have a loyalty card?",
            "Do you have cash?",
            "Do you have a bag?"
          ],
          "answer": "Do you have a loyalty card?",
          "answerMeaning": "Máte vernostnú kartu? = Do you have a loyalty card? Many Slovak supermarkets offer discounts with loyalty cards."
        },
        {
          "situation": "You didn't bring your own bag. What do you ask the cashier for?",
          "instruction": "Choose the correct phrase",
          "choices": ["Taška, prosím.", "Pol kila, prosím.", "Vozík, prosím.", "Účtenku?"],
          "answer": "Taška, prosím.",
          "answerMeaning": "Taška, prosím = A bag, please. In Slovakia bags are usually not free — you may need to ask and pay a small amount."
        },
        {
          "situation": "You're buying spices and only need a small amount, not much. What word fits?",
          "instruction": "Choose the correct word",
          "choices": ["Veľa", "Trochu", "Pol kila", "Vozík"],
          "answer": "Trochu",
          "answerMeaning": "Trochu = A little. The opposite of veľa (a lot) — useful when buying small quantities."
        }
      ]
