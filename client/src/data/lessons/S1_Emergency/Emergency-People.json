    {
      "id": "ex5",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You are injured and the dispatcher says a sanitka is coming. What is coming?",
          "instruction": "Choose the meaning",
          "choices": [
            "Ambulance",
            "Police officer",
            "Hospital",
            "Doctor"
          ],
          "answer": "Ambulance",
          "answerMeaning": "Sanitka = ambulance vehicle."
        },
        {
          "situation": "Someone says záchranár is helping the injured person. Who is helping?",
          "instruction": "Choose the meaning",
          "choices": [
            "Paramedic",
            "Police officer",
            "Firefighter",
            "Pharmacist"
          ],
          "answer": "Paramedic",
          "answerMeaning": "Záchranár = paramedic."
        },
        {
          "situation": "You need police help. Which word means police officer?",
          "instruction": "Choose the correct word",
          "choices": [
            "Policajt",
            "Doktor",
            "Hasiči",
            "Sanitka"
          ],
          "answer": "Policajt",
          "answerMeaning": "Policajt = police officer."
        },
        {
          "situation": "There is a fire. Which service do you need?",
          "instruction": "Choose the correct word",
          "choices": [
            "Hasiči",
            "Doktor",
            "Nemocnica",
            "Policajt"
          ],
          "answer": "Hasiči",
          "answerMeaning": "Hasiči = firefighters / fire department."
        },
        {
          "situation": "The ambulance takes someone to the nemocnica. Where are they going?",
          "instruction": "Choose the meaning",
          "choices": [
            "Hospital",
            "Police station",
            "Pharmacy",
            "Restaurant"
          ],
          "answer": "Hospital",
          "answerMeaning": "Nemocnica = hospital."
        }
      ]
    },
