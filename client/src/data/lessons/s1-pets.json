    {
      "id": "ex6",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "You are looking at a flat to rent. You have a cat. What is the most important question to ask the landlord?",
          "instruction": "Choose the correct phrase",
          "choices": ["Ako sa volá?", "Sú povolené zvieratá?", "Mám psa.", "Kŕmiť?"],
          "answer": "Sú povolené zvieratá?",
          "answerMeaning": "Sú povolené zvieratá? = Are pets allowed? Always ask this before signing any rental agreement if you have a pet."
        },
        {
          "situation": "Your neighbour asks if you have any pets. You have a dog. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["Mám psa.", "Mám mačku.", "Nemám zviera.", "Som pes."],
          "answer": "Mám psa.",
          "answerMeaning": "Mám psa = I have a dog. Mám from the Verbs lesson + psa (the accusative form of pes)."
        },
        {
          "situation": "Your neighbour's dog approaches you. You want to know its name. What do you ask?",
          "instruction": "Choose the correct phrase",
          "choices": ["Ako sa voláte?", "Ako sa volá?", "Odkiaľ ste?", "Kde bývate?"],
          "answer": "Ako sa volá?",
          "answerMeaning": "Ako sa volá? = What's its name? Same pattern as Ako sa voláte? from the Who I Am lesson — but without the formal -te ending, since you're asking about an animal, not a person."
        },
        {
          "situation": "Someone asks your cat's name. It's called Micka. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["Ako sa volá?", "Volá sa Micka.", "Mám mačku.", "Nemám zviera."],
          "answer": "Volá sa Micka.",
          "answerMeaning": "Volá sa Micka = Its name is Micka. Volá sa + name, the same pattern used for introducing people."
        },
        {
          "situation": "You don't currently have any pets. Someone asks. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["Mám psa.", "Mám mačku.", "Nemám zviera.", "Volá sa..."],
          "answer": "Nemám zviera.",
          "answerMeaning": "Nemám zviera = I don't have a pet. Nemám from the Verbs lesson — Ne- makes it negative."
        },
        {
          "situation": "Your dog hasn't eaten yet today. What do you need to do?",
          "instruction": "Choose the correct word",
          "choices": ["Venčiť", "Kŕmiť", "Volá sa", "Veterinár"],
          "answer": "Kŕmiť",
          "answerMeaning": "Kŕmiť = To feed. Potrebujem nakŕmiť psa = I need to feed the dog."
        },
        {
          "situation": "Your dog needs its evening walk. What do you need to do?",
          "instruction": "Choose the correct word",
          "choices": ["Kŕmiť", "Venčiť", "Veterinár", "Mám zviera"],
          "answer": "Venčiť",
          "answerMeaning": "Venčiť = To walk (a dog). Idem venčiť psa = I'm going to walk the dog."
        },
        {
          "situation": "Your cat is sick. Where do you need to take it?",
          "instruction": "Choose the correct word",
          "choices": ["Lekáreň", "Nemocnica", "Veterinár", "Recepcia"],
          "answer": "Veterinár",
          "answerMeaning": "Veterinár = Vet. Different from a doctor (lekár) — animals go to the veterinár, not the nemocnica."
        }
      ]
    },
