    {
      "id": "ex6",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "Your colleague asks if you have brothers or sisters. You have one brother. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["Mám sestru.", "Mám brata.", "Mám syna.", "Mám otca."],
          "answer": "Mám brata.",
          "answerMeaning": "Mám brata = I have a brother. Mám from the Verbs lesson + brat (brother)."
        },
        {
          "situation": "Someone asks where your parents live. You want to ask them the same question back. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": [
            "Kde bývate?",
            "Kde bývajú tvoji rodičia?",
            "Máte rodinu?",
            "Ako sa máte?"
          ],
          "answer": "Kde bývajú tvoji rodičia?",
          "answerMeaning": "Kde bývajú tvoji rodičia? = Where do your parents live? A very common question when getting to know someone in Slovakia."
        },
        {
          "situation": "You are filling in an official form. It asks about your relationship status. You are not married. What do you select?",
          "instruction": "Choose the correct word (you are male)",
          "choices": ["Ženatý", "Slobodný", "Vydatá", "Manžel"],
          "answer": "Slobodný",
          "answerMeaning": "Slobodný = Single (male form). Slobodná = Single (female form). Common on official forms and registrations."
        },
        {
          "situation": "Your neighbour asks about your wife's parents. Which Slovak word means 'wife'?",
          "instruction": "Choose the correct word",
          "choices": ["Manžel", "Manželka", "Sestra", "Dcéra"],
          "answer": "Manželka",
          "answerMeaning": "Manželka = Wife. Manžel = Husband. Notice the -ka suffix that often marks the female form in Slovak."
        },
        {
          "situation": "Your grandparents are visiting from abroad. How do you introduce your grandma to a Slovak friend?",
          "instruction": "Choose the correct phrase",
          "choices": ["To je môj dedko.", "To je moja babička.", "To je moja teta.", "To je moja sestra."],
          "answer": "To je moja babička.",
          "answerMeaning": "To je moja babička = This is my grandma. Babička is one of the most affectionately used words in Slovak family vocabulary."
        },
        {
          "situation": "You are describing your family. You have an uncle and an aunt who live nearby. Which two words do you use?",
          "instruction": "Choose the correct pair",
          "choices": [
            "Strýko a teta",
            "Bratranec a sesternica",
            "Dedko a babička",
            "Brat a sestra"
          ],
          "answer": "Strýko a teta",
          "answerMeaning": "Strýko = Uncle. Teta = Aunt. Different from Bratranec/Sesternica which mean cousin."
        },
        {
          "situation": "Someone asks if you are married. You are. You are a man. What do you say?",
          "instruction": "Choose the correct phrase",
          "choices": ["Som slobodný.", "Som ženatý.", "Som vydatá.", "Som syn."],
          "answer": "Som ženatý.",
          "answerMeaning": "Som ženatý = I am married (said by a man). A married woman says Som vydatá — different words for each gender."
        },
        {
          "situation": "Your cousin (female) is visiting. How do you introduce her to a colleague?",
          "instruction": "Choose the correct phrase",
          "choices": ["To je môj bratranec.", "To je moja sesternica.", "To je moja sestra.", "To je moja teta."],
          "answer": "To je moja sesternica.",
          "answerMeaning": "To je moja sesternica = This is my (female) cousin. Bratranec is the male cousin — Slovak distinguishes by gender."
        }
      ]
    },
