    {
      "id": "ex6",
      "type": "SITUATIONAL_CHOICE",
      "scenarios": [
        {
          "situation": "Smoke is pouring out of your neighbour's window. You call 150. What do you say first?",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Dobrý deň!", "Je tu požiar! Adresa je...", "Ukradli mi peňaženku!", "Potrebujem doktora!"],
          "answer": "Je tu požiar! Adresa je...",
          "answerMeaning": "There's a fire here! The address is... (always give your address first!)"
        },
        {
          "situation": "Someone collapses on the street. You call 155. What do you say?",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Je tu požiar!", "Ukradli mi tašku!", "Niekto je zranený! Pošlite záchranku!", "Potrebujem políciu!"],
          "answer": "Niekto je zranený! Pošlite záchranku!",
          "answerMeaning": "Someone is injured! Send an ambulance!"
        },
        {
          "situation": "Your wallet was pickpocketed on the tram. Which number do you call?",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["155", "150", "158", "112"],
          "answer": "158",
          "answerMeaning": "Police — 158 (crime and theft)"
        },
        {
          "situation": "The police dispatcher picks up. The first thing they need from you is...",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Je to núdza!", "Volám sa Peter. Som na Hlavnej ulici.", "Dobrý deň!", "Zavolajte doktora!"],
          "answer": "Volám sa Peter. Som na Hlavnej ulici.",
          "answerMeaning": "My name is Peter. I am on Hlavná street. (from Lesson 3 — name + location first!)"
        },
        {
          "situation": "You witness a road crash — there are injured people and a car on fire. You need police, ambulance and fire. Which single number reaches all three at once?",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["155", "158", "150", "112"],
          "answer": "112",
          "answerMeaning": "112 — the general emergency number that dispatches police, ambulance and fire together"
        },
        {
          "situation": "It's 2pm. You walk into the ambulancia to see the doctor. How do you greet the receptionist?",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Ahoj!", "Dobré ráno!", "Dobrý deň!", "Dovidenia!"],
          "answer": "Dobrý deň!",
          "answerMeaning": "Good day! (formal daytime greeting — from Lesson 2)"
        },
        {
          "situation": "The doctor's report describes you as a man, but you are a woman. How do you correct them?",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Som muž.", "Som chorá.", "Som žena.", "Som vysoká."],
          "answer": "Som žena.",
          "answerMeaning": "I am a woman. (from Lesson 3)"
        },
        {
          "situation": "The doctor asks how you feel. You feel very unwell. What do you say?",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Je mi dobre.", "Som vysoký.", "Je mi zle.", "Teší ma."],
          "answer": "Je mi zle.",
          "answerMeaning": "I feel unwell."
        },
        {
          "situation": "Police need your nationality for their report. You are from India. What do you say?",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Teší ma.", "Som z Indie.", "Som chorý.", "Dovidenia."],
          "answer": "Som z Indie.",
          "answerMeaning": "I am from India. (from Lesson 3)"
        },
        {
          "situation": "Someone snatches your bag and runs. What do you shout? (You learned a better word than Pomoc! in this lesson.)",
          "instruction": "Choose the most appropriate phrase",
          "choices": ["Požiar!", "Nehoda!", "Záchranár!", "Zlodej!"],
          "answer": "Zlodej!",
          "answerMeaning": "Thief! (more specific than Pomoc! from Lesson 1)"
        }
      ]
